import math
from collections import defaultdict, deque
from typing import List, Dict, Callable, Tuple

def rcpsp_solver(jobs: List[Dict], resources_borders: List[Dict], communication_coefficient: Callable[[int, int], float] = None) -> Tuple[Dict, List, Dict, Dict, int]:
    # Helper functions
    def validate_jobs(jobs: List[Dict]):
        job_ids = set()
        for job in jobs:
            if job['id'] in job_ids:
                raise ValueError("Duplicate job ID")
            job_ids.add(job['id'])
            if not all(key in job for key in ['id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority']):
                raise ValueError("Job missing required fields")
            if isinstance(job['predecessors'], str):
                job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
            if not isinstance(job['predecessors'], list):
                raise ValueError("Invalid predecessors format")
            for pred in job['predecessors']:
                if pred not in job_ids:
                    raise ValueError(f"Predecessor {pred} not found for job {job['id']}")

    def detect_cycles(jobs: List[Dict]):
        graph = {job['id']: set(job['predecessors']) for job in jobs}
        visited = set()
        path = set()

        def dfs(node):
            if node in path:
                return False
            if node in visited:
                return True
            visited.add(node)
            path.add(node)
            for neighbor in graph[node]:
                if not dfs(neighbor):
                    return False
            path.remove(node)
            return True

        for job in jobs:
            if not dfs(job['id']):
                raise ValueError("Cycle detected in precedence graph")

    def validate_resources(jobs: List[Dict], resources_borders: List[Dict]):
        if not resources_borders and jobs:
            raise ValueError("No resources available while jobs exist")
        for job in jobs:
            for resource, work_volume in job['work_volume'].items():
                if work_volume > 0:
                    feasible = False
                    for contractor in resources_borders:
                        if contractor['workers'].get(resource, 0) >= job['demand_min'][resource]:
                            feasible = True
                            break
                    if not feasible:
                        raise ValueError(f"No feasible contractor for job {job['id']}")

    def compute_duration(job: Dict, allocated: Dict[str, int]):
        if communication_coefficient:
            return max(math.ceil(job['work_volume'][r] / (allocated[r] * communication_coefficient(allocated[r], job['demand_max'][r])) for r in job['work_volume'] if job['work_volume'][r] > 0))
        else:
            return max(math.ceil(job['work_volume'][r] / allocated[r]) for r in job['work_volume'] if job['work_volume'][r] > 0)

    def check_resources(contractor_id: str, job: Dict, start_time: int, end_time: int, resource_usage: Dict):
        for t in range(start_time, end_time):
            for resource, demand_min in job['demand_min'].items():
                if resource_usage[contractor_id][t][resource] + demand_min > contractor['workers'][resource]:
                    return False
        return True

    def allocate_resources(contractor_id: str, job: Dict, start_time: int, end_time: int, resource_usage: Dict, job_usage: Dict):
        allocated = {}
        for resource, demand_min in job['demand_min'].items():
            allocated[resource] = min(job['demand_max'][resource], min(contractor['workers'][resource] - resource_usage[contractor_id][t][resource] for t in range(start_time, end_time)))
            for t in range(start_time, end_time):
                resource_usage[contractor_id][t][resource] += allocated[resource]
        job_usage[job['id']] = allocated

    # Pre-loop validation
    validate_jobs(jobs)
    detect_cycles(jobs)
    validate_resources(jobs, resources_borders)

    # Initialize data structures
    job_dict = {job['id']: job for job in jobs}
    contractor_dict = {contractor['id']: contractor for contractor in resources_borders}
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    job_usage = {}
    schedule = {}
    execution_order = []
    makespan = 0
    current_time = 0
    active_jobs = set()
    unscheduled_jobs = set(job_dict.keys())
    pending_predecessors = {job['id']: len(job['predecessors']) for job in jobs}
    completed_jobs = set()

    # Calculate ES and LF
    def calculate_earliest_latest_times():
        # Forward pass (ES)
        es = {job['id']: 0 for job in jobs}
        queue = deque([job['id'] for job in jobs if not job['predecessors']])
        while queue:
            job_id = queue.popleft()
            job = job_dict[job_id]
            for successor_id in job['successors']:
                es[successor_id] = max(es[successor_id], es[job_id] + compute_duration(job, job['demand_max']))
                queue.append(successor_id)

        # Backward pass (LF)
        lf = {job['id']: es[job_id] + compute_duration(job, job['demand_max']) for job_id, job in job_dict.items()}
        queue = deque([job['id'] for job in jobs if not job['successors']])
        while queue:
            job_id = queue.popleft()
            job = job_dict[job_id]
            for predecessor_id in job['predecessors']:
                lf[predecessor_id] = min(lf[predecessor_id], lf[job_id] - compute_duration(job_dict[predecessor_id], job_dict[predecessor_id]['demand_max']))
                queue.append(predecessor_id)

        return es, lf

    es, lf = calculate_earliest_latest_times()

    # Priority ordering
    priorities = [(job['id'], job['priority']) for job in jobs]
    priorities.sort(key=lambda x: -x[1])

    # Main loop
    while unscheduled_jobs:
        # COMPLETE
        for job_id in list(schedule.keys()):
            if schedule[job_id][2] <= current_time and job_id not in completed_jobs:
                completed_jobs.add(job_id)
                for successor_id in job_dict[job_id]['successors']:
                    pending_predecessors[successor_id] -= 1

        # ELIGIBLE
        eligible_jobs = [job_id for job_id in unscheduled_jobs if pending_predecessors[job_id] == 0]

        # SCHEDULE
        for job_id in priorities:
            if job_id not in eligible_jobs:
                continue
            job = job_dict[job_id]
            feasible_contractors = []
            for contractor_id, contractor in contractor_dict.items():
                if all(contractor['workers'].get(resource, 0) >= demand_min for resource, demand_min in job['demand_min'].items() if job['work_volume'][resource] > 0):
                    start_time = es[job_id]
                    end_time = start_time + compute_duration(job, job['demand_max'])
                    if check_resources(contractor_id, job, start_time, end_time, resource_usage):
                        feasible_contractors.append((contractor_id, sum(contractor['workers'].values())))

            if feasible_contractors:
                feasible_contractors.sort(key=lambda x: (x[1], x[0]))
                contractor_id = feasible_contractors[0][0]
                start_time = es[job_id]
                end_time = start_time + compute_duration(job, job['demand_max'])
                allocate_resources(contractor_id, job, start_time, end_time, resource_usage, job_usage)
                schedule[job_id] = (contractor_id, start_time, end_time)
                execution_order.append(job_id)
                unscheduled_jobs.remove(job_id)
                active_jobs.add(job_id)
                makespan = max(makespan, end_time)

        # ADVANCE
        if not active_jobs and unscheduled_jobs:
            raise ValueError("Deadlock detected")
        if not active_jobs:
            break
        current_time = min(schedule[job_id][2] for job_id in active_jobs)

    return schedule, execution_order, resource_usage, job_usage, makespan