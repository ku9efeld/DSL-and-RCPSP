import math
from collections import defaultdict, deque
from typing import List, Dict, Callable, Tuple

def rcpsp_solver(jobs: List[Dict], resources_borders: List[Dict], communication_coefficient: Callable[[int, int], float] = None) -> Tuple[Dict, List, Dict, Dict, int]:
    # Helper functions
    def validate_jobs(jobs: List[Dict]):
        job_ids = set()
        for job in jobs:
            if job['id'] in job_ids:
                raise ValueError("Duplicate job ID")
            job_ids.add(job['id'])
            if not all(key in job for key in ['id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority']):
                raise ValueError("Job missing required fields")
            if isinstance(job['predecessors'], str):
                job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
            if not isinstance(job['predecessors'], list):
                raise ValueError("Invalid predecessors format")
    
    def validate_predecessors(jobs: List[Dict]):
        job_ids = {job['id'] for job in jobs}
        for job in jobs:
            for pred in job['predecessors']:
                if pred not in job_ids:
                    raise ValueError(f"Missing predecessor {pred} for job {job['id']}")
    
    def detect_cycles(jobs: List[Dict]):
        graph = {job['id']: set(job['predecessors']) for job in jobs}
        indegree = {job['id']: len(job['predecessors']) for job in jobs}
        queue = deque([job['id'] for job in jobs if indegree[job['id']] == 0])
        
        visited = 0
        while queue:
            node = queue.popleft()
            visited += 1
            for neighbor in graph:
                if node in graph[neighbor]:
                    graph[neighbor].remove(node)
                    indegree[neighbor] -= 1
                    if indegree[neighbor] == 0:
                        queue.append(neighbor)
        
        if visited != len(jobs):
            raise ValueError("Cycle detected in precedence graph")
    
    def validate_resources(jobs: List[Dict], resources_borders: List[Dict]):
        if not resources_borders and jobs:
            raise ValueError("No contractors available while jobs exist")
        
        for job in jobs:
            for contractor in resources_borders:
                feasible = True
                for resource, work_volume in job['work_volume'].items():
                    if work_volume > 0 and (resource not in contractor['workers'] or contractor['workers'][resource] < job['demand_min'][resource]):
                        feasible = False
                        break
                if feasible:
                    break
            else:
                raise ValueError(f"No feasible contractor for job {job['id']}")
    
    def compute_duration(job: Dict, allocated: Dict[str, int], communication_coefficient: Callable[[int, int], float] = None) -> int:
        durations = []
        for resource, work_volume in job['work_volume'].items():
            if work_volume > 0:
                if communication_coefficient:
                    productivity = allocated[resource] * communication_coefficient(allocated[resource], job['demand_max'][resource])
                else:
                    productivity = allocated[resource]
                durations.append(math.ceil(work_volume / productivity))
        return max(durations)
    
    def check_resources(contractor_id: str, job: Dict, current_time: int, allocated: Dict[str, int], resource_usage: Dict) -> bool:
        for t in range(current_time, current_time + compute_duration(job, allocated, communication_coefficient)):
            for resource, demand_min in job['demand_min'].items():
                if resource_usage[contractor_id][t][resource] + allocated[resource] < demand_min:
                    return False
        return True
    
    def allocate_resources(contractor_id: str, job: Dict, current_time: int, allocated: Dict[str, int], resource_usage: Dict):
        end_time = current_time + compute_duration(job, allocated, communication_coefficient)
        for t in range(current_time, end_time):
            for resource, amount in allocated.items():
                resource_usage[contractor_id][t][resource] += amount
    
    def get_feasible_contractors(job: Dict, current_time: int, resource_usage: Dict) -> List[Dict]:
        feasible_contractors = []
        for contractor in resources_borders:
            allocated = {resource: min(job['demand_max'][resource], contractor['workers'][resource]) for resource in job['work_volume']}
            if check_resources(contractor['id'], job, current_time, allocated, resource_usage):
                feasible_contractors.append((contractor, allocated))
        return feasible_contractors
    
    def select_contractor(feasible_contractors: List[Tuple[Dict, Dict]]) -> Tuple[Dict, Dict]:
        return min(feasible_contractors, key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
    
    # Pre-loop validation
    validate_jobs(jobs)
    validate_predecessors(jobs)
    detect_cycles(jobs)
    validate_resources(jobs, resources_borders)
    
    # Initialize data structures
    job_dict = {job['id']: job for job in jobs}
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    schedule = {}
    execution_order = []
    job_usage = {job['id']: defaultdict(int) for job in jobs}
    makespan = 0
    current_time = 0
    unscheduled = set(job['id'] for job in jobs)
    active_jobs = []
    pending_predecessors = {job['id']: len(job['predecessors']) for job in jobs}
    
    # Calculate earliest start times (EST)
    est = {job['id']: 0 for job in jobs}
    for job in jobs:
        for pred in job['predecessors']:
            est[job['id']] = max(est[job['id']], est[pred] + compute_duration(job_dict[pred], job_dict[pred]['demand_max']))
    
    # Sort jobs by EST
    sorted_jobs = sorted(jobs, key=lambda x: est[x['id']])
    
    # Main scheduling loop
    while unscheduled:
        # COMPLETE: Mark completed jobs and update pending predecessors
        for job_id, (contractor_id, start_time, end_time) in list(schedule.items()):
            if end_time <= current_time:
                for successor in job_dict[job_id]['successors']:
                    pending_predecessors[successor] -= 1
                del schedule[job_id]
        
        # ELIGIBLE: Collect all unscheduled jobs with no pending predecessors
        eligible_jobs = [job for job in sorted_jobs if job['id'] in unscheduled and pending_predecessors[job['id']] == 0]
        
        # SCHEDULE: Attempt to assign each eligible job
        for job in eligible_jobs:
            feasible_contractors = get_feasible_contractors(job, current_time, resource_usage)
            if feasible_contractors:
                contractor, allocated = select_contractor(feasible_contractors)
                start_time = current_time
                end_time = start_time + compute_duration(job, allocated, communication_coefficient)
                allocate_resources(contractor['id'], job, start_time, allocated, resource_usage)
                schedule[job['id']] = (contractor['id'], start_time, end_time)
                execution_order.append(job['id'])
                unscheduled.remove(job['id'])
                for resource, amount in allocated.items():
                    job_usage[job['id']][resource] += amount
                active_jobs.append((job['id'], end_time))
                makespan = max(makespan, end_time)
        
        # ADVANCE: Advance current_time if no job was scheduled
        if not eligible_jobs and unscheduled:
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(end_time for _, end_time in active_jobs)
    
    return schedule, execution_order, resource_usage, job_usage, makespan