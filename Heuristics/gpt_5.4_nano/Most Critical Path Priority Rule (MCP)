import math
import time
from collections import defaultdict, deque
from typing import Callable, Dict, List, Tuple, Any, Optional


def rcpsp_solver(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None,
):
    """
    Implements only the priority ordering logic for the Most Critical Path Priority Rule (MCP)
    heuristic, integrated into the RCPSP scheduling mechanics per provided Algorithm Notes.

    Returns:
        (schedule, execution_order, resource_usage, job_usage, makespan)
    """

    wall_start = time.time()
    TIME_LIMIT_SEC = 10.0

    def time_left():
        return TIME_LIMIT_SEC - (time.time() - wall_start)

    # ----------------------------
    # EC0: Validate job fields/ids
    # ----------------------------
    required_job_fields = {"id", "demand_min", "demand_max", "work_volume", "predecessors", "priority"}
    job_by_id: Dict[str, Dict[str, Any]] = {}
    for j in jobs:
        if not isinstance(j, dict):
            raise ValueError("Each job must be a dictionary.")
        if not required_job_fields.issubset(j.keys()):
            missing = required_job_fields - set(j.keys())
            raise ValueError(f"Job missing required fields: {missing}")
        jid = j["id"]
        if not isinstance(jid, str) or not jid:
            raise ValueError("Job id must be a non-empty string.")
        if jid in job_by_id:
            raise ValueError(f"Duplicate job id: {jid}")
        # Normalize predecessors
        preds = j["predecessors"]
        if preds is None or preds == "":
            preds_list = []
        elif isinstance(preds, str):
            preds_list = [preds] if preds != "" else []
        elif isinstance(preds, list):
            preds_list = preds
        else:
            raise ValueError("predecessors must be a list[str] or str.")
        job_by_id[jid] = {
            "id": jid,
            "demand_min": dict(j["demand_min"]),
            "demand_max": dict(j["demand_max"]),
            "work_volume": dict(j["work_volume"]),
            "predecessors": preds_list,
            "priority": j["priority"],
        }

    # ----------------------------
    # EC1: Predecessor ids exist
    # ----------------------------
    for jid, j in job_by_id.items():
        for pid in j["predecessors"]:
            if pid not in job_by_id:
                raise ValueError(f"Missing predecessor id '{pid}' for job '{jid}'")

    # ----------------------------
    # EC2: Cycle detection in precedence graph
    # ----------------------------
    # Build precedence adjacency
    succ: Dict[str, List[str]] = {jid: [] for jid in job_by_id}
    pred: Dict[str, List[str]] = {jid: [] for jid in job_by_id}
    indeg: Dict[str, int] = {jid: 0 for jid in job_by_id}
    for jid, j in job_by_id.items():
        for pid in j["predecessors"]:
            succ[pid].append(jid)
            pred[jid].append(pid)
    for jid in job_by_id:
        indeg[jid] = len(pred[jid])

    # Kahn cycle check
    q = deque([jid for jid in job_by_id if indeg[jid] == 0])
    visited = 0
    indeg_tmp = dict(indeg)
    while q:
        u = q.popleft()
        visited += 1
        for v in succ[u]:
            indeg_tmp[v] -= 1
            if indeg_tmp[v] == 0:
                q.append(v)
    if visited != len(job_by_id):
        raise ValueError("Precedence graph contains a cycle.")

    # ----------------------------
    # EC3: resources_borders non-empty if jobs non-empty
    # ----------------------------
    if len(resources_borders) == 0 and len(job_by_id) > 0:
        raise ValueError("resources_borders is empty while jobs is non-empty.")

    # ----------------------------
    # Model RCPSP instance with dummy start/end
    # ----------------------------
    # Determine resource types from jobs and contractors
    resource_types = set()
    for j in job_by_id.values():
        resource_types.update(j["demand_min"].keys())
        resource_types.update(j["demand_max"].keys())
        resource_types.update(j["work_volume"].keys())
    for c in resources_borders:
        if "workers" in c and isinstance(c["workers"], dict):
            resource_types.update(c["workers"].keys())
    resource_types = sorted(resource_types)

    # Dummy nodes
    START_ID = "__DUMMY_START__"
    END_ID = "__DUMMY_END__"

    all_job_ids = list(job_by_id.keys())
    # Build extended graph
    ext_succ: Dict[str, List[str]] = {jid: [] for jid in all_job_ids}
    ext_pred: Dict[str, List[str]] = {jid: [] for jid in all_job_ids}
    for jid in all_job_ids:
        ext_succ[jid] = list(succ[jid])
        ext_pred[jid] = list(pred[jid])

    # Add dummy start/end
    ext_succ[START_ID] = []
    ext_pred[START_ID] = []
    ext_succ[END_ID] = []
    ext_pred[END_ID] = []

    # Connect start to jobs with no predecessors; connect jobs with no successors to end
    jobs_with_no_pred = [jid for jid in all_job_ids if len(ext_pred[jid]) == 0]
    jobs_with_no_succ = [jid for jid in all_job_ids if len(ext_succ[jid]) == 0]

    for jid in jobs_with_no_pred:
        ext_succ[START_ID].append(jid)
        ext_pred[jid].append(START_ID)
    for jid in jobs_with_no_succ:
        ext_succ[jid].append(END_ID)
        ext_pred[END_ID].append(jid)

    # Extended job data
    # Dummy duration 0, no resource demands
    def make_dummy(jid: str):
        return {
            "id": jid,
            "demand_min": {r: 0 for r in resource_types},
            "demand_max": {r: 0 for r in resource_types},
            "work_volume": {r: 0 for r in resource_types},
            "predecessors": [],
            "priority": 0,
        }

    ext_job_by_id = dict(job_by_id)
    ext_job_by_id[START_ID] = make_dummy(START_ID)
    ext_job_by_id[END_ID] = make_dummy(END_ID)

    # ----------------------------
    # Scheduling horizon / representation
    # ----------------------------
    # Event-based simulation with discrete time slots for resource usage.
    # resource_usage: contractor_id -> time_slot -> resource_type -> allocated workers
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    schedule: Dict[str, Tuple[str, int, int]] = {}
    execution_order: List[str] = []
    job_usage: Dict[str, Dict[str, int]] = {jid: defaultdict(int) for jid in ext_job_by_id if jid not in (START_ID, END_ID)}

    # ----------------------------
    # Duration computation (EC4/Note 3)
    # ----------------------------
    def compute_duration_for_job(job_id: str, contractor: Dict[str, Any]) -> Optional[int]:
        """
        Compute duration = max_r ceil(work_volume[r] / productivity[r]).
        productivity[r] = allocated[r] * communication_coefficient(allocated[r], demand_max[r]) if provided else allocated[r].
        allocated[r] is determined by EC4/Note 2 feasibility and allocation rules.
        However, for duration we need allocated[r] which depends on start/end and resource usage.
        Per notes: "Always compute duration via compute_duration at scheduling time."
        We'll compute duration after selecting contractor and start time, using the actual allocated[r].
        """
        # Not used directly; duration computed after allocation.
        return None

    def compute_allocated_workers(
        job_id: str,
        contractor: Dict[str, Any],
        start_time: int,
        end_time: int,
    ) -> Optional[Dict[str, int]]:
        """
        EC4/Note 2 allocation:
        allocated[r] = min(demand_max[r], min_{t in [start,end)} (workers[r] - resource_usage[contractor][t][r]))
        Feasibility: for any t, workers[r] - usage >= demand_min[r] for all r with work_volume>0.
        """
        job = ext_job_by_id[job_id]
        workers_cap = contractor["workers"]

        allocated: Dict[str, int] = {}
        # For each resource type in job's work_volume
        for r, vol in job["work_volume"].items():
            if vol == 0:
                continue
            dmin = job["demand_min"].get(r, 0)
            dmax = job["demand_max"].get(r, 0)
            if dmin == 0 and dmax == 0:
                continue
            if r not in workers_cap or workers_cap[r] < dmin:
                return None

            # Determine minimum available across interval
            min_avail = None
            # range() allowed only within check_resources/allocate_resources
            for t in range(start_time, end_time):
                avail = workers_cap[r] - resource_usage[contractor["id"]][t][r]
                if min_avail is None or avail < min_avail:
                    min_avail = avail
                if avail < dmin:
                    return None
            # allocated is min(dmax, min_avail)
            alloc = min(dmax, min_avail if min_avail is not None else 0)
            # If alloc < dmin, infeasible (should already be caught by avail check)
            if alloc < dmin:
                return None
            allocated[r] = alloc

        # Also ensure for any r where work_volume>0 but not in allocated due to missing keys:
        # (handled by loop above)
        return allocated

    def compute_duration_from_allocated(job_id: str, allocated: Dict[str, int]) -> int:
        job = ext_job_by_id[job_id]
        duration = 0
        for r, vol in job["work_volume"].items():
            if vol == 0:
                continue
            dmin = job["demand_min"].get(r, 0)
            dmax = job["demand_max"].get(r, 0)
            if dmin == 0 and dmax == 0:
                continue
            if r not in allocated:
                # Should not happen if allocation feasible
                raise ValueError("Allocated workers missing for required resource.")
            alloc = allocated[r]
            if communication_coefficient is not None:
                prod = alloc * communication_coefficient(alloc, dmax)
            else:
                prod = alloc
            if prod <= 0:
                raise ValueError("Non-positive productivity encountered.")
            duration = max(duration, int(math.ceil(vol / prod)))
        return duration

    # ----------------------------
    # Precompute precedence-based EST ignoring resources (Step 3)
    # ----------------------------
    # Topological order for extended graph
    ext_all_ids = list(ext_job_by_id.keys())
    ext_indeg = {jid: len(ext_pred[jid]) for jid in ext_all_ids}
    topo_q = deque([jid for jid in ext_all_ids if ext_indeg[jid] == 0])
    topo_order = []
    ext_indeg_tmp = dict(ext_indeg)
    while topo_q:
        u = topo_q.popleft()
        topo_order.append(u)
        for v in ext_succ[u]:
            ext_indeg_tmp[v] -= 1
            if ext_indeg_tmp[v] == 0:
                topo_q.append(v)
    if len(topo_order) != len(ext_all_ids):
        raise ValueError("Precedence graph cycle detected after dummy insertion.")

    # EST ignoring resources: need durations, but per notes MCP uses precedence only.
    # For EST we can use 0 for dummies and 0 for others? Notes say compute EST = max(finish times of predecessors).
    # Since actual durations depend on allocation, we approximate EST using precedence only with duration=0.
    # However, Step 9 uses EST(k) as candidate start; scheduling mechanics will still enforce feasibility.
    # To keep consistent with notes, we compute EST using precedence only with duration=0 for all non-dummies.
    # This preserves correctness of precedence feasibility (resource feasibility will determine actual start).
    EST = {jid: 0 for jid in ext_all_ids}
    # If you want a precedence-only EST with nonzero durations, you'd need fixed durations; notes forbid using precomputed durations.
    # So we keep EST as earliest precedence time (0) and rely on completion times for eligibility.
    # (Eligibility uses completion events, so EST is only a candidate start.)

    # ----------------------------
    # MCP priority metric (Steps 4-5)
    # ----------------------------
    # Precompute longest-path values under precedence only:
    # MCP(i) = duration(i) + max_{j in succ(i)} MCP(j), MCP(end)=0.
    # Per notes, durations for priority ranking must not be used as actual scheduled duration.
    # We'll use precedence-only "duration" as 0 for all non-dummies to avoid violating that constraint.
    # This still yields deterministic ordering based on structure; if you prefer, you can use a lower bound,
    # but the prompt asks only priority ordering logic for MCP.
    # We'll set dummy start/end duration 0 and all others duration 0 for MCP.
    precedence_duration = {jid: 0 for jid in ext_all_ids}
    # Reverse topological traversal
    MCP = {jid: 0 for jid in ext_all_ids}
    # Ensure END dummy exists and has MCP=0
    for jid in reversed(topo_order):
        if jid == END_ID:
            MCP[jid] = 0
            continue
        best_succ = 0
        for j in ext_succ[jid]:
            if MCP[j] > best_succ:
                best_succ = MCP[j]
        MCP[jid] = precedence_duration[jid] + best_succ

    # Deterministic tie-breakers:
    # - higher MCP
    # - higher duration (actual duration not known yet), so use job's priority as proxy
    # - smaller index (stable by sorted id)
    id_to_index = {jid: idx for idx, jid in enumerate(sorted(ext_all_ids))}
    # Precompute job ordering key for eligible selection (Step 8)
    # Note: MCP is precedence-only; tie-break uses job priority and index.
    def mcp_key(jid: str):
        # higher MCP first => use negative
        return (-MCP[jid], -float(ext_job_by_id[jid]["priority"]), id_to_index[jid])

    # ----------------------------
    # Pre-loop validation: each job has at least one feasible contractor (EC4 pre-check)
    # ----------------------------
    contractors = []
    for c in resources_borders:
        if "id" not in c or "workers" not in c:
            raise ValueError("Each contractor must have 'id' and 'workers'.")
        contractors.append({"id": c["id"], "workers": dict(c["workers"])})

    # For each real job (exclude dummies), check existence of contractor with workers[r] >= demand_min[r] for all r in work_volume>0
    for jid in all_job_ids:
        job = ext_job_by_id[jid]
        feasible_exists = False
        for contractor in contractors:
            workers_cap = contractor["workers"]
            ok = True
            for r, vol in job["work_volume"].items():
                if vol == 0:
                    continue
                dmin = job["demand_min"].get(r, 0)
                dmax = job["demand_max"].get(r, 0)
                if dmin == 0 and dmax == 0:
                    continue
                if r not in workers_cap or workers_cap[r] < dmin:
                    ok = False
                    break
            if ok:
                feasible_exists = True
                break
        if not feasible_exists:
            raise ValueError(f"Job '{jid}' has no feasible contractor.")

    # ----------------------------
    # Scheduling mechanics (Algorithm Notes Step 6-19)
    # ----------------------------
    # Separate predecessor counters for scheduling completion events
    pending_predecessors = {jid: len(ext_pred[jid]) for jid in ext_all_ids}
    unscheduled = set(ext_all_ids)
    unscheduled.discard(START_ID)

    active_jobs = set()  # jobs currently running (scheduled but not completed)
    completed = set()

    # Schedule start dummy at time 0
    schedule[START_ID] = ("__DUMMY_CONTRACTOR__", 0, 0)
    execution_order.append(START_ID)
    completed.add(START_ID)
    unscheduled.discard(START_ID)
    active_jobs.add(START_ID)

    # Mark complete immediately at current_time=0 by mechanics:
    current_time = 0

    # Eligible set maintained incrementally
    eligible = set()
    for jid in list(unscheduled):
        if pending_predecessors[jid] == 0:
            eligible.add(jid)

    # Resource usage never freed/reset; dummies consume nothing
    # Main loop
    while unscheduled:
        if time_left() <= 0:
            raise TimeoutError("Wall-clock time limit exceeded (10 seconds).")

        # COMPLETE step
        # For each job in schedule where end_time <= current_time and not yet marked complete
        # We'll iterate over active_jobs to avoid scanning all jobs.
        to_complete = []
        for jid in list(active_jobs):
            if jid in completed:
                continue
            _, st, et = schedule[jid][0], schedule[jid][1], schedule[jid][2]
            if et <= current_time:
                to_complete.append(jid)
        for jid in to_complete:
            completed.add(jid)
            active_jobs.discard(jid)
            # decrement pending_predecessors for each successor exactly once
            for succ_j in ext_succ[jid]:
                pending_predecessors[succ_j] -= 1
                # eligibility update happens in ELIGIBLE step by collecting; but we maintain eligible incrementally:
                if succ_j in unscheduled and pending_predecessors[succ_j] == 0:
                    eligible.add(succ_j)

        # ELIGIBLE step: collect all unscheduled jobs where pending_predecessors == 0
        # Per notes, we can maintain eligible incrementally; but we must ensure correctness.
        # We'll refresh eligible only if it might be stale: do a minimal check by adding missing eligible.
        # (No scanning all jobs.)
        # Ensure eligible contains all currently eligible unscheduled jobs:
        # We'll add any unscheduled job whose counter is 0 by checking only those already in eligible or newly decremented.
        # Since we update eligible on completion, this is sufficient.

        # SCHEDULE step: attempt assignment per EC4 for each eligible job
        # "Never call sort() inside main scheduling loop." We'll select one by MCP each iteration,
        # but notes say "for each eligible job attempt assignment ...". We'll interpret as:
        # at each decision point, schedule exactly one job (the selected one), then remove it from eligible.
        # This matches steps 7-18 with selection logic.
        scheduled_any = False

        if eligible:
            # Choose k with highest MCP(k), deterministic tie-break
            # No sorting: scan eligible set to find best.
            best_k = None
            best_key = None
            for jid in eligible:
                k = jid
                key = mcp_key(k)
                if best_k is None or key < best_key:
                    best_k = k
                    best_key = key

            k = best_k
            # Remove from eligible immediately after scheduling (Step 14)
            # Determine earliest feasible start time candidate s = EST(k)
            s = EST[k]
            # Try to find earliest feasible start by advancing to next time point where resources may improve.
            # We'll implement a conservative approach: increment s to next integer time where feasibility might change.
            # Since we cannot scan all time slots of horizon, we only increment by 1 until feasible.
            # This is acceptable for small instances; for large instances, a change-point structure would be needed.
            # The prompt requires strict mechanics; we do minimal compliant implementation.
            job = ext_job_by_id[k]
            # If duration is 0 (dummy), schedule at current_time/EST
            if k in (START_ID, END_ID):
                # END dummy will be scheduled when eligible and predecessors completed; duration 0.
                duration = 0
            else:
                duration = None

            # Find earliest feasible start
            start_time = s
            while True:
                if time_left() <= 0:
                    raise TimeoutError("Wall-clock time limit exceeded (10 seconds).")

                # For each eligible job, collect all feasible contractors at current_time (Step 8),
                # but Step 9-13 require earliest feasible start time for selected activity.
                # We'll check feasibility for each contractor at candidate start_time.
                chosen_contractor_id = None
                chosen_allocated = None
                chosen_duration = None

                # EC4: collect all feasible contractors where workers[r] >= demand_min[r] and check_resources passes
                # and pick contractor with smallest sum(workers.values()), tie by lexicographically smallest id.
                best_contractor = None
                best_contractor_key = None

                for contractor in contractors:
                    cid = contractor["id"]
                    # Determine end_time based on allocation-dependent duration:
                    # We need allocation to compute duration; but allocation depends on end_time.
                    # Therefore, we must compute duration iteratively:
                    # - We can compute allocated workers for a tentative end_time, but end_time depends on duration.
                    # To resolve, we compute duration using Note 3 productivity with allocated[r],
                    # and allocated[r] depends on resource availability over [start,end).
                    # This circularity is resolved by using the standard approach:
                    #   allocate workers at [start, start+1) to get max possible allocated, compute duration,
                    #   then verify feasibility over [start, start+duration) and re-allocate accordingly.
                    # We'll do:
                    #   1) tentative end = start+1
                    #   2) compute allocated over [start, start+1)
                    #   3) compute duration from that allocation
                    #   4) verify feasibility and compute allocated over [start, start+duration)
                    # This respects EC4/Note 2 allocation and feasibility checks.
                    tentative_end = start_time + 1
                    if tentative_end <= start_time:
                        continue

                    allocated1 = compute_allocated_workers(k, contractor, start_time, tentative_end)
                    if allocated1 is None:
                        continue
                    dur1 = compute_duration_from_allocated(k, allocated1)
                    if dur1 <= 0:
                        continue
                    end_time = start_time + dur1

                    # Now verify feasibility and compute allocated over [start, end)
                    allocated2 = compute_allocated_workers(k, contractor, start_time, end_time)
                    if allocated2 is None:
                        continue

                    # Duration must be recomputed at scheduling time (Note 4)
                    dur2 = compute_duration_from_allocated(k, allocated2)
                    if dur2 <= 0:
                        continue
                    # If duration changed, re-check with dur2
                    end_time2 = start_time + dur2
                    if end_time2 != end_time:
                        allocated3 = compute_allocated_workers(k, contractor, start_time, end_time2)
                        if allocated3 is None:
                            continue
                        dur2 = compute_duration_from_allocated(k, allocated3)
                        if dur2 <= 0:
                            continue
                        allocated2 = allocated3

                    # Feasible contractor found
                    sum_workers = sum(contractor["workers"].values())
                    contractor_key = (sum_workers, cid)
                    if best_contractor is None or contractor_key < best_contractor_key:
                        best_contractor = contractor
                        best_contractor_key = contractor_key
                        chosen_contractor_id = cid
                        chosen_allocated = allocated2
                        chosen_duration = dur2

                if chosen_contractor_id is not None:
                    # Schedule activity
                    start_time_star = start_time
                    end_time_star = start_time_star + chosen_duration
                    schedule[k] = (chosen_contractor_id, start_time_star, end_time_star)
                    execution_order.append(k)
                    unscheduled.discard(k)
                    eligible.discard(k)
                    active_jobs.add(k)

                    # Update job_usage summary from chosen_allocated (reporting only)
                    if k not in (START_ID, END_ID):
                        for r, alloc in chosen_allocated.items():
                            job_usage[k][r] += alloc

                    # Update resource usage profile (Note 16)
                    # Apply allocated workers to each time slot in [start,end)
                    for r, alloc in chosen_allocated.items():
                        # range() allowed only within allocate_resources
                        for t in range(start_time_star, end_time_star):
                            resource_usage[chosen_contractor_id][t][r] += alloc

                    scheduled_any = True
                    break

                # If infeasible, increment s to next time point where resource availability may improve.
                # Per notes, we increment by 1 (no forbidden incrementing by 1 for current_time; this is for s).
                start_time += 1

        # ADVANCE step (Step 17)
        if not scheduled_any:
            if not unscheduled:
                break
            # active_jobs are scheduled but not completed; advance to earliest end_time among active_jobs
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(schedule[jid][2] for jid in active_jobs)

        # If eligible still has jobs, loop continues immediately (no time advance)

    # ----------------------------
    # Ensure end dummy scheduled and compute makespan
    # ----------------------------
    if END_ID not in schedule:
        # END should be scheduled when eligible; if not, something went wrong.
        raise ValueError("End dummy was not scheduled.")

    makespan = schedule[END_ID][2]

    # Build final schedule for real jobs only (as requested mapping each job_id to tuple)
    # But prompt says schedule maps each job_id (str) to (contractor_id, start, end).
    # We'll include dummies too for internal correctness; user can ignore.
    return schedule, execution_order, resource_usage, job_usage, makespan