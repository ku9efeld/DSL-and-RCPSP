import math
from collections import defaultdict, deque
import time

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    start_time_wall = time.time()
    
    # EC0: Validate job fields and uniqueness
    job_ids = set()
    for job in jobs:
        if not isinstance(job, dict):
            raise ValueError("Each job must be a dictionary")
        required_fields = ['id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority']
        for field in required_fields:
            if field not in job:
                raise ValueError(f"Job missing required field: {field}")
        if job['id'] in job_ids:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_ids.add(job['id'])
        
        # Normalize predecessors to list
        if isinstance(job['predecessors'], str):
            job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
    
    # EC1: Validate predecessor existence
    all_job_ids = {job['id'] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            if pred_id not in all_job_ids:
                raise ValueError(f"Predecessor {pred_id} not found for job {job['id']}")
    
    # EC2: Check for cycles in precedence graph
    def has_cycle():
        graph = {job['id']: [] for job in jobs}
        indegree = {job['id']: 0 for job in jobs}
        
        for job in jobs:
            for pred_id in job['predecessors']:
                graph[pred_id].append(job['id'])
                indegree[job['id']] += 1
        
        queue = deque([jid for jid, deg in indegree.items() if deg == 0])
        visited = 0
        
        while queue:
            node = queue.popleft()
            visited += 1
            for neighbor in graph[node]:
                indegree[neighbor] -= 1
                if indegree[neighbor] == 0:
                    queue.append(neighbor)
        
        return visited != len(jobs)
    
    if has_cycle():
        raise ValueError("Precedence graph contains a cycle")
    
    # EC3: Validate resources_borders
    if not resources_borders and jobs:
        raise ValueError("No contractors provided for non-empty job list")
    
    # Create job lookup dictionary
    job_dict = {job['id']: job for job in jobs}
    
    # Step 2: Build precedence graph and compute total successors count
    successors = {job['id']: [] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            successors[pred_id].append(job['id'])
    
    # Compute total successors count for each job (including indirect successors)
    total_successors = {}
    
    def count_total_successors(start_job_id, visited):
        """Count all successors reachable from start_job_id"""
        count = 0
        stack = [start_job_id]
        local_visited = set()
        
        while stack:
            current = stack.pop()
            if current in local_visited:
                continue
            local_visited.add(current)
            
            for succ in successors[current]:
                if succ not in local_visited:
                    count += 1
                    stack.append(succ)
        
        return count
    
    # Compute total successors for each job
    for job in jobs:
        total_successors[job['id']] = count_total_successors(job['id'], set())
    
    # Step 3: Initialize scheduling structures
    # Note 9: Verify each job has at least one feasible contractor
    for job in jobs:
        feasible = False
        for contractor in resources_borders:
            workers = contractor['workers']
            # Check if contractor has minimum required resources
            min_requirements_met = True
            for r, volume in job['work_volume'].items():
                if volume > 0:
                    if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                        min_requirements_met = False
                        break
            if min_requirements_met:
                feasible = True
                break
        if not feasible:
            raise ValueError(f"No feasible contractor for job {job['id']}")
    
    # Initialize scheduling state
    current_time = 0
    schedule = {}  # job_id -> (contractor_id, start_time, end_time)
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    
    # Track job states
    unscheduled_jobs = set(job['id'] for job in jobs)
    active_jobs = set()  # jobs that are currently executing
    completed_jobs = set()
    
    # Predecessor counters for scheduling
    pending_predecessors = {job['id']: len(job['predecessors']) for job in jobs}
    
    # Helper functions
    def check_resources(contractor_id, workers, job, start_time, duration):
        """Check if resources are available for the entire duration"""
        for t in range(start_time, start_time + duration):
            for r in job['work_volume']:
                if job['work_volume'][r] > 0:
                    available = workers[r] - resource_usage[contractor_id][t][r]
                    if available < job['demand_min'].get(r, 0):
                        return False
        return True
    
    def allocate_resources(contractor_id, job, start_time, duration, allocated):
        """Allocate resources for the job"""
        for t in range(start_time, start_time + duration):
            for r, count in allocated.items():
                resource_usage[contractor_id][t][r] += count
    
    def compute_duration(job, allocated):
        """Compute actual duration based on allocated resources"""
        durations = []
        for r, volume in job['work_volume'].items():
            if volume > 0 and allocated.get(r, 0) > 0:
                if communication_coefficient:
                    productivity = allocated[r] * communication_coefficient(
                        allocated[r], job['demand_max'].get(r, 0)
                    )
                else:
                    productivity = allocated[r]
                if productivity > 0:
                    durations.append(math.ceil(volume / productivity))
        return max(durations) if durations else 1
    
    # Main scheduling loop
    while unscheduled_jobs:
        if time.time() - start_time_wall > 10:
            raise TimeoutError("Execution time limit exceeded")
        
        # Step 5.1: COMPLETE - Mark completed jobs
        newly_completed = set()
        for job_id in list(active_jobs):
            _, start, end = schedule[job_id]
            if end <= current_time and job_id not in completed_jobs:
                completed_jobs.add(job_id)
                newly_completed.add(job_id)
                active_jobs.remove(job_id)
                
                # Update predecessor counters for successors
                for succ_id in successors[job_id]:
                    pending_predecessors[succ_id] -= 1
        
        # Step 5.2: ELIGIBLE - Collect eligible jobs
        eligible = []
        for job_id in unscheduled_jobs:
            if pending_predecessors[job_id] == 0:
                eligible.append(job_id)
        
        # Sort eligible jobs by MTS priority (precomputed total successors count)
        # Sort in descending order for most total successors first
        # This is allowed as it's precomputed before the main loop
        eligible.sort(key=lambda jid: (-total_successors[jid], jid))
        
        # Step 5.3: SCHEDULE - Attempt to schedule eligible jobs
        scheduled_this_iteration = False
        
        for job_id in eligible[:]:  # Iterate over copy as we modify the list
            if time.time() - start_time_wall > 10:
                raise TimeoutError("Execution time limit exceeded")
                
            job = job_dict[job_id]
            feasible_contractors = []
            
            # EC4: Collect feasible contractors
            for contractor in resources_borders:
                contractor_id = contractor['id']
                workers = contractor['workers']
                
                # Check minimum requirements
                min_req_met = True
                for r, volume in job['work_volume'].items():
                    if volume > 0:
                        if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                            min_req_met = False
                            break
                if not min_req_met:
                    continue
                
                # Determine resource allocation
                allocated = {}
                for r in job['work_volume']:
                    if job['work_volume'][r] > 0:
                        # Allocate as many as available up to demand_max
                        max_available = min(
                            job['demand_max'].get(r, 0),
                            workers[r] - resource_usage[contractor_id][current_time].get(r, 0)
                        )
                        allocated[r] = max_available
                
                # Compute duration with these allocations
                duration = compute_duration(job, allocated)
                if duration is None:
                    continue
                
                # Check resource availability for entire duration
                if check_resources(contractor_id, workers, job, current_time, duration):
                    feasible_contractors.append((contractor, allocated, duration))
            
            if not feasible_contractors:
                continue
            
            # Select contractor per EC4
            # Sort by sum of workers (resource capacity), then by contractor id
            feasible_contractors.sort(key=lambda x: (
                sum(x[0]['workers'].values()),
                x[0]['id']
            ))
            
            selected_contractor, allocated, duration = feasible_contractors[0]
            contractor_id = selected_contractor['id']
            
            # Allocate resources
            allocate_resources(contractor_id, job, current_time, duration, allocated)
            
            # Schedule the job
            end_time = current_time + duration
            schedule[job_id] = (contractor_id, current_time, end_time)
            execution_order.append(job_id)
            unscheduled_jobs.remove(job_id)
            active_jobs.add(job_id)
            scheduled_this_iteration = True
            
            # Remove from eligible list
            eligible.remove(job_id)
        
        # Step 5.4: ADVANCE - Advance time if no jobs were scheduled
        if not scheduled_this_iteration:
            if not active_jobs and unscheduled_jobs:
                # EC5: Deadlock detection
                raise ValueError("Deadlock detected")
            
            if active_jobs:
                # Advance to next completion time
                next_completion = min(
                    schedule[job_id][2] for job_id in active_jobs
                )
                if next_completion <= current_time:
                    raise ValueError("Time advancement error")
                current_time = next_completion
            else:
                # Should not happen due to EC5 check above
                current_time += 1
    
    makespan = max(end_time for _, _, end_time in schedule.values())
    
    return schedule, execution_order, resource_usage, makespan