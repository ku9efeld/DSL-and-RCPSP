import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    for j in jobs:
        if not all(k in j for k in ['id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority']):
            raise ValueError("Missing job fields")
        if j['id'] in job_map:
            raise ValueError("Duplicate job ID")
        # Normalize predecessors
        preds = j['predecessors']
        j['predecessors'] = [preds] if isinstance(preds, str) and preds else (preds if isinstance(preds, list) else [])
        job_map[j['id']] = j

    # EC1: Validate predecessor existence
    for j in jobs:
        for p in j['predecessors']:
            if p not in job_map:
                raise ValueError("Missing predecessor")

    # EC2: Cycle detection (Kahn's)
    in_degree = {j['id']: 0 for j in jobs}
    adj = defaultdict(list)
    for j in jobs:
        for p in j['predecessors']:
            adj[p].append(j['id'])
            in_degree[j['id']] += 1
    
    queue = deque([j['id'] for j in jobs if in_degree[j['id']] == 0])
    visited_count = 0
    while queue:
        u = queue.popleft()
        visited_count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0: queue.append(v)
    if visited_count != len(jobs): raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs: raise ValueError("No resources")

    # LPT Priority: Calculate total work volume (sum of successors)
    def get_total_work(job_id, memo):
        if job_id in memo: return memo[job_id]
        j = job_map[job_id]
        # Sum of work_volume across all resources
        self_work = sum(j['work_volume'].values())
        memo[job_id] = self_work + sum(get_total_work(succ, memo) for succ in adj[job_id])
        return memo[job_id]

    work_memo = {}
    for j in jobs: get_total_work(j['id'], work_memo)
    for j in jobs: j['lpt_priority'] = work_memo[j['id']]

    # Note 9: Feasibility check
    for j in jobs:
        feasible = False
        for c in resources_borders:
            if all(c['workers'].get(r, 0) >= j['demand_min'].get(r, 0) for r in j['work_volume'] if j['work_volume'][r] > 0):
                feasible = True; break
        if not feasible: raise ValueError("No feasible contractor")

    # Scheduling
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    pending_preds = {j['id']: len(j['predecessors']) for j in jobs}
    unscheduled = {j['id'] for j in jobs}
    active_jobs = {} # id: end_time
    completed = set()
    current_time = 0

    def compute_duration(job, allocated):
        dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0): continue
            prod = allocated[r] * (communication_coefficient(allocated[r], job['demand_max'][r]) if communication_coefficient else 1)
            dur = max(dur, math.ceil(vol / prod) if prod > 0 else float('inf'))
        return int(dur)

    while unscheduled or active_jobs:
        # 1. COMPLETE
        finished = [jid for jid, end in active_jobs.items() if end <= current_time]
        for jid in finished:
            if jid not in completed:
                completed.add(jid)
                for succ in adj[jid]: pending_preds[succ] -= 1
                del active_jobs[jid]

        # 2. ELIGIBLE
        eligible = [jid for jid in unscheduled if pending_preds[jid] == 0]
        # Sort by LPT (descending)
        eligible.sort(key=lambda x: job_map[x]['lpt_priority'], reverse=True)

        # 3. SCHEDULE
        scheduled_any = False
        for jid in eligible[:]:
            job = job_map[jid]
            best_c = None
            best_dur = 0
            best_alloc = {}
            
            candidates = []
            for c in resources_borders:
                # Check static feasibility
                if not all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in job['work_volume'] if job['work_volume'][r] > 0): continue
                
                # Calculate allocation
                alloc = {r: min(job['demand_max'].get(r, 0), c['workers'].get(r, 0)) for r in job['work_volume']}
                dur = compute_duration(job, alloc)
                
                # Check resource availability over [current_time, current_time + dur)
                possible = True
                for t in range(current_time, current_time + dur):
                    for r, val in alloc.items():
                        if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < job['demand_min'].get(r, 0):
                            possible = False; break
                    if not possible: break
                
                if possible: candidates.append((c, dur, alloc))
            
            if candidates:
                # Pick contractor: smallest sum of workers, then lexicographical ID
                best_c, best_dur, best_alloc = min(candidates, key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                
                # Allocate
                for t in range(current_time, current_time + best_dur):
                    for r, val in best_alloc.items():
                        resource_usage[best_c['id']][t][r] += val
                
                schedule[jid] = (best_c['id'], current_time, current_time + best_dur)
                active_jobs[jid] = current_time + best_dur
                job_usage[jid] = best_alloc
                execution_order.append(jid)
                unscheduled.remove(jid)
                scheduled_any = True

        # 4. ADVANCE
        if not scheduled_any:
            if not active_jobs: raise ValueError("Deadlock detected")
            current_time = min(active_jobs.values())

    return schedule, execution_order, resource_usage, job_usage, current_time