import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(k in job for k in required_fields):
            raise ValueError("Missing fields in job")
        if job['id'] in job_map:
            raise ValueError("Duplicate job ID")
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            job['predecessors'] = [preds] if preds else []
        job_map[job['id']] = job

    # EC1: Validate predecessor existence
    for job in jobs:
        for p_id in job['predecessors']:
            if p_id not in job_map:
                raise ValueError(f"Predecessor {p_id} not found")

    # EC2: Cycle detection (Kahn's algorithm)
    in_degree = {j_id: 0 for j_id in job_map}
    adj = defaultdict(list)
    for j_id, job in job_map.items():
        for p_id in job['predecessors']:
            adj[p_id].append(j_id)
            in_degree[j_id] += 1
    
    queue = deque([j for j in in_degree if in_degree[j] == 0])
    count = 0
    while queue:
        u = queue.popleft()
        count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0: queue.append(v)
    if count != len(job_map): raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs: raise ValueError("No resources")

    # MOS: Calculate number of successors
    successors_count = {j_id: 0 for j_id in job_map}
    def count_succ(u):
        for v in adj[u]:
            successors_count[v] += 1
            count_succ(v)
    for j_id in job_map:
        if not job_map[j_id]['predecessors']: count_succ(j_id)

    # Note 9: Feasibility check
    for j_id, job in job_map.items():
        feasible = False
        for c in resources_borders:
            if all(job['demand_min'].get(r, 0) <= c['workers'].get(r, 0) 
                   for r in job['work_volume'] if job['work_volume'][r] > 0):
                feasible = True; break
        if not feasible: raise ValueError(f"No feasible contractor for {j_id}")

    # Scheduling state
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    pending_predecessors = {j_id: len(job['predecessors']) for j_id, job in job_map.items()}
    unscheduled = set(job_map.keys())
    active_jobs = {} # id -> end_time
    completed = set()
    current_time = 0

    def get_duration(job, allocated):
        dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0): continue
            prod = allocated[r] * (communication_coefficient(allocated[r], job['demand_max'][r]) if communication_coefficient else 1)
            dur = max(dur, math.ceil(vol / prod) if prod > 0 else float('inf'))
        return int(dur)

    while unscheduled or active_jobs:
        # 1. COMPLETE
        finished = [jid for jid, end in active_jobs.items() if end <= current_time]
        for jid in finished:
            if jid not in completed:
                completed.add(jid)
                for succ in adj[jid]: pending_predecessors[succ] -= 1
                del active_jobs[jid]

        # 2. ELIGIBLE
        eligible = [jid for jid in unscheduled if pending_predecessors[jid] == 0]
        # Rank by MOS (descending)
        eligible.sort(key=lambda x: successors_count[x], reverse=True)

        # 3. SCHEDULE
        for jid in eligible:
            job = job_map[jid]
            best_c = None
            best_alloc = None
            best_dur = 0
            
            # EC4: Find best contractor
            candidates = []
            for c in resources_borders:
                # Check feasibility
                possible = True
                alloc = {}
                for r, d_max in job['demand_max'].items():
                    d_min = job['demand_min'].get(r, 0)
                    if c['workers'].get(r, 0) < d_min:
                        possible = False; break
                    # Check capacity for duration
                    # Note: duration depends on allocation, but we need duration to check capacity
                    # Simplified: assume max allocation for feasibility check
                    alloc[r] = min(d_max, c['workers'].get(r, 0))
                
                if not possible: continue
                dur = get_duration(job, alloc)
                
                # Check resource availability over [current_time, current_time + dur)
                for t in range(current_time, current_time + dur):
                    for r, d_min in job['demand_min'].items():
                        if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < d_min:
                            possible = False; break
                    if not possible: break
                
                if possible: candidates.append((c, alloc, dur))

            if candidates:
                # Pick smallest sum of workers, tie-break ID
                best_c, best_alloc, best_dur = min(candidates, key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                
                # Allocate
                for t in range(current_time, current_time + best_dur):
                    for r, val in best_alloc.items():
                        resource_usage[best_c['id']][t][r] += val
                
                schedule[jid] = (best_c['id'], current_time, current_time + best_dur)
                job_usage[jid] = best_alloc
                execution_order.append(jid)
                unscheduled.remove(jid)
                active_jobs[jid] = current_time + best_dur

        # 4. ADVANCE
        if active_jobs:
            current_time = min(active_jobs.values())
        elif unscheduled:
            raise ValueError("Deadlock detected")

    makespan = max((end for end in active_jobs.values()), default=current_time)
    return schedule, execution_order, resource_usage, job_usage, makespan