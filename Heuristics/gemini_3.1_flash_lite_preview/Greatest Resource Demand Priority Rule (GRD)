import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(k in job for k in required_fields):
            raise ValueError("Missing fields in job definition")
        if job['id'] in job_map:
            raise ValueError("Duplicate job ID")
        # Normalize predecessors
        preds = job['predecessors']
        job['predecessors'] = [preds] if isinstance(preds, str) and preds else (preds if isinstance(preds, list) else [])
        job_map[job['id']] = job

    # EC1: Validate predecessor existence
    for job in jobs:
        for p_id in job['predecessors']:
            if p_id not in job_map:
                raise ValueError(f"Predecessor {p_id} not found")

    # EC2: Cycle detection (Kahn's)
    in_degree = {j['id']: len(j['predecessors']) for j in jobs}
    adj = defaultdict(list)
    for j in jobs:
        for p in j['predecessors']:
            adj[p].append(j['id'])
    queue = deque([j['id'] for j in jobs if in_degree[j['id']] == 0])
    count = 0
    while queue:
        u = queue.popleft()
        count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0: queue.append(v)
    if count != len(jobs): raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs: raise ValueError("No resources")

    # Note 9: Feasibility check
    for job in jobs:
        feasible = False
        for c in resources_borders:
            if all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) 
                   for r in job['work_volume'] if job['work_volume'][r] > 0 and not (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0)):
                feasible = True; break
        if not feasible: raise ValueError(f"No feasible contractor for {job['id']}")

    # GRD Priority Calculation
    def get_grd(job):
        duration_est = 1 # Heuristic estimate
        total_res = sum(job['demand_max'].values())
        return duration_est * total_res

    for j in jobs: j['grd'] = get_grd(j)
    
    # State
    current_time = 0
    unscheduled = {j['id']: j for j in jobs}
    in_progress = {} # id: (contractor_id, end_time)
    completed = set()
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = defaultdict(dict)
    pending_preds = {j['id']: len(j['predecessors']) for j in jobs}

    def compute_duration(job, contractor, allocated):
        dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0): continue
            prod = allocated[r] * (communication_coefficient(allocated[r], job['demand_max'][r]) if communication_coefficient else 1)
            dur = max(dur, math.ceil(vol / prod))
        return dur

    while unscheduled or in_progress:
        # 1. COMPLETE
        finished = [jid for jid, (cid, et) in in_progress.items() if et <= current_time]
        for jid in finished:
            completed.add(jid)
            del in_progress[jid]
            for succ in adj[jid]:
                pending_preds[succ] -= 1

        # 2. ELIGIBLE
        eligible = [j for jid, j in unscheduled.items() if pending_preds[jid] == 0]
        eligible.sort(key=lambda x: x['grd'], reverse=True)

        # 3. SCHEDULE
        scheduled_any = False
        for job in eligible:
            best_c = None
            best_dur = 0
            best_alloc = {}
            
            candidates = []
            for c in resources_borders:
                # Check basic capacity
                if not all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in job['work_volume'] if job['work_volume'][r] > 0): continue
                
                # Determine allocation
                alloc = {r: min(job['demand_max'].get(r, 0), c['workers'].get(r, 0)) for r in job['work_volume']}
                dur = compute_duration(job, c, alloc)
                
                # Check resource availability over [t, t+dur)
                possible = True
                for t in range(current_time, current_time + dur):
                    for r, val in alloc.items():
                        if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < job['demand_min'].get(r, 0):
                            possible = False; break
                    if not possible: break
                
                if possible: candidates.append((c, dur, alloc))
            
            if candidates:
                # EC4: Pick contractor
                candidates.sort(key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                c, dur, alloc = candidates[0]
                
                # Allocate
                for t in range(current_time, current_time + dur):
                    for r, val in alloc.items(): resource_usage[c['id']][t][r] += val
                
                schedule[job['id']] = (c['id'], current_time, current_time + dur)
                in_progress[job['id']] = (c['id'], current_time + dur)
                job_usage[job['id']] = alloc
                execution_order.append(job['id'])
                del unscheduled[job['id']]
                scheduled_any = True

        # 4. ADVANCE
        if not scheduled_any and unscheduled:
            if not in_progress: raise ValueError("Deadlock detected")
            current_time = min(et for cid, et in in_progress.values())

    makespan = max((et for cid, et in in_progress.values()), default=current_time)
    return schedule, execution_order, resource_usage, job_usage, makespan