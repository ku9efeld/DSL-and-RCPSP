import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    seen_ids = set()
    for job in jobs:
        if not required_fields.issubset(job.keys()):
            raise ValueError("Missing fields in job")
        if job['id'] in seen_ids:
            raise ValueError("Duplicate job ID")
        seen_ids.add(job['id'])
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            job['predecessors'] = [preds] if preds else []
        job_map[job['id']] = job

    # EC1: Validate predecessor existence
    for job in jobs:
        for p in job['predecessors']:
            if p not in job_map:
                raise ValueError(f"Predecessor {p} not found")

    # EC2: Cycle detection (Kahn's)
    in_degree = {j['id']: len(j['predecessors']) for j in jobs}
    adj = defaultdict(list)
    for j in jobs:
        for p in j['predecessors']:
            adj[p].append(j['id'])
    queue = deque([j['id'] for j in jobs if in_degree[j['id']] == 0])
    count = 0
    while queue:
        u = queue.popleft()
        count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0:
                queue.append(v)
    if count != len(jobs):
        raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs:
        raise ValueError("No resources provided")

    # Note 9: Feasibility check
    for job in jobs:
        feasible = False
        for c in resources_borders:
            possible = True
            for r, vol in job['work_volume'].items():
                if vol > 0 and not (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0):
                    if r not in c['workers'] or c['workers'][r] < job['demand_min'].get(r, 0):
                        possible = False
                        break
            if possible:
                feasible = True
                break
        if not feasible:
            raise ValueError(f"Job {job['id']} has no feasible contractor")

    # Precompute EST (Simple CPM)
    est = {j['id']: 0 for j in jobs}
    for _ in range(len(jobs)):
        for j in jobs:
            for p in j['predecessors']:
                est[j['id']] = max(est[j['id']], est[p] + 1) # Simplified duration 1 for EST ranking

    def compute_duration(job, allocated):
        dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0):
                continue
            prod = allocated[r]
            if communication_coefficient:
                prod *= communication_coefficient(allocated[r], job['demand_max'].get(r, 0))
            dur = max(dur, math.ceil(vol / prod))
        return dur

    # Scheduling state
    current_time = 0
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    pending_predecessors = {j['id']: len(j['predecessors']) for j in jobs}
    completed = set()
    active_jobs = {} # id -> end_time
    unscheduled = {j['id']: j for j in jobs}

    while unscheduled or active_jobs:
        # 1. COMPLETE
        finished_this_step = [jid for jid, end in active_jobs.items() if end <= current_time]
        for jid in finished_this_step:
            completed.add(jid)
            del active_jobs[jid]
            for successor in adj[jid]:
                pending_predecessors[successor] -= 1

        # 2. ELIGIBLE
        eligible = [j for jid, j in unscheduled.items() if pending_predecessors[jid] == 0]
        eligible.sort(key=lambda x: est[x['id']])

        # 3. SCHEDULE
        scheduled_any = False
        for job in eligible:
            best_c = None
            best_dur = 0
            best_alloc = {}
            
            # Find feasible contractors
            candidates = []
            for c in resources_borders:
                # Check min requirements
                if not all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in job['work_volume']):
                    continue
                
                # Calculate max allocation
                alloc = {}
                for r in job['work_volume']:
                    limit = c['workers'].get(r, 0)
                    alloc[r] = min(job['demand_max'].get(r, 0), limit)
                
                dur = compute_duration(job, alloc)
                
                # Check resource availability for [current_time, current_time + dur)
                possible = True
                for t in range(current_time, current_time + dur):
                    for r in job['work_volume']:
                        if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < job['demand_min'].get(r, 0):
                            possible = False; break
                    if not possible: break
                
                if possible:
                    candidates.append((c, dur, alloc))
            
            if candidates:
                # Pick contractor: smallest sum of workers, then lexicographical ID
                candidates.sort(key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                c, dur, alloc = candidates[0]
                
                # Allocate
                for t in range(current_time, current_time + dur):
                    for r, val in alloc.items():
                        resource_usage[c['id']][t][r] += val
                
                schedule[job['id']] = (c['id'], current_time, current_time + dur)
                job_usage[job['id']] = alloc
                execution_order.append(job['id'])
                active_jobs[job['id']] = current_time + dur
                del unscheduled[job['id']]
                scheduled_any = True

        # 4. ADVANCE
        if not scheduled_any and unscheduled:
            if not active_jobs: raise ValueError("Deadlock detected")
            current_time = min(active_jobs.values())

    makespan = max((end for end in active_jobs.values()), default=current_time)
    return schedule, execution_order, resource_usage, job_usage, makespan