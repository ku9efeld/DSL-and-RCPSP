import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(k in job for k in required_fields):
            raise ValueError("Missing fields in job definition")
        if job['id'] in job_map:
            raise ValueError("Duplicate job ID")
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            job['predecessors'] = [preds] if preds else []
        job_map[job['id']] = job

    # EC1: Validate predecessor existence
    for job in jobs:
        for p in job['predecessors']:
            if p not in job_map:
                raise ValueError(f"Predecessor {p} not found")

    # EC2: Cycle detection (Kahn's)
    in_degree = {j['id']: len(j['predecessors']) for j in jobs}
    adj = defaultdict(list)
    for j in jobs:
        for p in j['predecessors']:
            adj[p].append(j['id'])
    
    queue = deque([j['id'] for j in jobs if in_degree[j['id']] == 0])
    count = 0
    while queue:
        u = queue.popleft()
        count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0:
                queue.append(v)
    if count != len(jobs):
        raise ValueError("Cycle detected in precedence graph")

    # EC3: Resources check
    if not resources_borders and jobs:
        raise ValueError("No resources available")

    # Note 9: Feasibility check
    for job in jobs:
        feasible = False
        for c in resources_borders:
            if all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) 
                   for r in job['work_volume'] if job['work_volume'][r] > 0):
                feasible = True
                break
        if not feasible:
            raise ValueError(f"Job {job['id']} has no feasible contractor")

    def compute_duration(job, contractor, allocated):
        max_dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0):
                continue
            prod = allocated[r]
            if communication_coefficient:
                prod *= communication_coefficient(allocated[r], job['demand_max'].get(r, 0))
            max_dur = max(max_dur, math.ceil(vol / prod))
        return max_dur

    # State initialization
    current_time = 0
    completed = set()
    scheduled = set()
    active_jobs = {} # id -> (contractor_id, end_time)
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    job_usage = defaultdict(dict)
    schedule = {}
    execution_order = []
    pending_preds = {j['id']: len(j['predecessors']) for j in jobs}

    while len(completed) < len(jobs):
        # 1. COMPLETE
        finished_this_step = [jid for jid, (cid, et) in active_jobs.items() if et <= current_time]
        for jid in finished_this_step:
            completed.add(jid)
            for successor in adj[jid]:
                pending_preds[successor] -= 1
            del active_jobs[jid]

        # 2. ELIGIBLE
        eligible = [j for j in jobs if j['id'] not in scheduled and j['id'] not in active_jobs and pending_preds[j['id']] == 0]
        # SPT Rule: Sort by duration (using min demand as proxy for duration estimation if needed, 
        # but here we use the priority field as requested by the prompt's SPT logic)
        eligible.sort(key=lambda x: x['priority'])

        # 3. SCHEDULE
        scheduled_any = False
        for job in eligible:
            best_contractor = None
            best_duration = float('inf')
            best_alloc = {}
            
            # EC4: Find best contractor
            candidates = []
            for c in resources_borders:
                # Check feasibility
                possible = True
                alloc = {}
                for r, vol in job['work_volume'].items():
                    if vol == 0: continue
                    avail = c['workers'].get(r, 0)
                    if avail < job['demand_min'].get(r, 0):
                        possible = False; break
                    alloc[r] = min(job['demand_max'].get(r, 0), avail)
                
                if possible:
                    dur = compute_duration(job, c, alloc)
                    # Check resource availability over [current_time, current_time + dur)
                    for t in range(current_time, current_time + dur):
                        for r, val in alloc.items():
                            if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < val:
                                possible = False; break
                        if not possible: break
                
                if possible:
                    candidates.append((c, alloc, dur))
            
            if candidates:
                # Pick smallest sum of workers, then lexicographical ID
                best_c, best_alloc, best_dur = min(candidates, key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                
                # Allocate
                for t in range(current_time, current_time + best_dur):
                    for r, val in best_alloc.items():
                        resource_usage[best_c['id']][t][r] += val
                
                schedule[job['id']] = (best_c['id'], current_time, current_time + best_dur)
                active_jobs[job['id']] = (best_c['id'], current_time + best_dur)
                job_usage[job['id']] = best_alloc
                execution_order.append(job['id'])
                scheduled.add(job['id'])
                scheduled_any = True

        # 4. ADVANCE
        if not scheduled_any and len(completed) < len(jobs):
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(et for _, et in active_jobs.values())

    return schedule, execution_order, resource_usage, job_usage, current_time