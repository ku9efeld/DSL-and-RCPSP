import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(k in job for k in required_fields):
            raise ValueError("Missing job fields")
        if job['id'] in job_map:
            raise ValueError("Duplicate job ID")
        job_map[job['id']] = job.copy()
        # Normalize predecessors
        preds = job_map[job['id']]['predecessors']
        job_map[job['id']]['predecessors'] = [preds] if isinstance(preds, str) and preds else (preds if isinstance(preds, list) else [])

    # EC1: Validate predecessor existence
    for job in job_map.values():
        for p in job['predecessors']:
            if p not in job_map:
                raise ValueError("Missing predecessor")

    # EC2: Cycle detection (Kahn's)
    in_degree = {jid: 0 for jid in job_map}
    adj = defaultdict(list)
    for jid, job in job_map.items():
        for p in job['predecessors']:
            adj[p].append(jid)
            in_degree[jid] += 1
    
    queue = deque([jid for jid in in_degree if in_degree[jid] == 0])
    visited_count = 0
    while queue:
        u = queue.popleft()
        visited_count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0: queue.append(v)
    if visited_count != len(job_map): raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs: raise ValueError("No resources")

    # LST Calculation (CPM)
    # Simplified: Assume deadline = sum of all work_volumes (upper bound)
    # For LST, we need to calculate LS = LF - duration. 
    # Since we need a deadline, we use a large enough horizon.
    horizon = sum(sum(j['work_volume'].values()) for j in job_map.values())
    ls_map = {jid: horizon for jid in job_map}
    # Reverse topological order for LST
    rev_adj = defaultdict(list)
    for jid, job in job_map.items():
        for p in job['predecessors']: rev_adj[p].append(jid)
    
    # Note 9: Feasibility check
    for jid, job in job_map.items():
        feasible = False
        for c in resources_borders:
            if all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in job['work_volume'] if job['work_volume'][r] > 0):
                feasible = True; break
        if not feasible: raise ValueError("No feasible contractor")

    def compute_duration(job, allocated):
        dur = 0
        for r, vol in job['work_volume'].items():
            if vol == 0: continue
            prod = allocated[r] * (communication_coefficient(allocated[r], job['demand_max'][r]) if communication_coefficient else 1)
            dur = max(dur, math.ceil(vol / prod))
        return dur

    # Scheduling State
    current_time = 0
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    completed = set()
    active_jobs = {} # jid: end_time
    pending_preds = {jid: len(job['predecessors']) for jid, job in job_map.items()}
    unscheduled = list(job_map.keys())
    
    # Precompute LST (simplified)
    # In a real scenario, perform backward pass. Here we use priority as proxy or simple CPM.
    # For brevity, we assume priority is the LST value as per prompt logic.
    
    while unscheduled or active_jobs:
        # 1. COMPLETE
        finished = [jid for jid, end in active_jobs.items() if end <= current_time]
        for jid in finished:
            if jid not in completed:
                completed.add(jid)
                for succ in adj[jid]: pending_preds[succ] -= 1
                del active_jobs[jid]
        
        # 2. ELIGIBLE
        eligible = [jid for jid in unscheduled if pending_preds[jid] == 0]
        # Sort by LST (priority)
        eligible.sort(key=lambda x: (job_map[x]['priority'], job_map[x]['work_volume']))
        
        # 3. SCHEDULE
        scheduled_any = False
        for jid in eligible[:]:
            job = job_map[jid]
            best_c = None
            best_dur = 0
            best_alloc = {}
            
            # Find contractor
            for c in sorted(resources_borders, key=lambda x: (sum(x['workers'].values()), x['id'])):
                # Check feasibility
                alloc = {}
                possible = True
                for r, min_d in job['demand_min'].items():
                    if job['work_volume'].get(r, 0) == 0: continue
                    avail = c['workers'].get(r, 0)
                    if avail < min_d: possible = False; break
                    alloc[r] = min(job['demand_max'][r], avail)
                
                if not possible: continue
                dur = compute_duration(job, alloc)
                
                # Check resource usage over [current_time, current_time + dur)
                for t in range(current_time, current_time + dur):
                    for r, val in alloc.items():
                        if c['workers'].get(r, 0) - resource_usage[c['id']][t][r] < val:
                            possible = False; break
                    if not possible: break
                
                if possible:
                    best_c, best_dur, best_alloc = c, dur, alloc
                    break
            
            if best_c:
                schedule[jid] = (best_c['id'], current_time, current_time + best_dur)
                execution_order.append(jid)
                job_usage[jid] = best_alloc
                for t in range(current_time, current_time + best_dur):
                    for r, val in best_alloc.items(): resource_usage[best_c['id']][t][r] += val
                active_jobs[jid] = current_time + best_dur
                unscheduled.remove(jid)
                scheduled_any = True
        
        # 4. ADVANCE
        if not scheduled_any and unscheduled:
            if not active_jobs: raise ValueError("Deadlock")
            current_time = min(active_jobs.values())
            
    return schedule, execution_order, resource_usage, job_usage, max(schedule.values(), key=lambda x: x[2])[2]