import math
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    # EC0: Validate fields and unique IDs
    job_map = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(k in job for k in required_fields):
            raise ValueError("Missing job fields")
        if job['id'] in job_map:
            raise ValueError("Duplicate job ID")
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            job['predecessors'] = [preds] if preds else []
        job_map[job['id']] = job

    # EC1: Validate predecessor existence
    for job in jobs:
        for p in job['predecessors']:
            if p not in job_map:
                raise ValueError(f"Predecessor {p} not found")

    # EC2: Cycle detection (Kahn's)
    in_degree = {jid: len(job['predecessors']) for jid, job in job_map.items()}
    adj = defaultdict(list)
    for jid, job in job_map.items():
        for p in job['predecessors']:
            adj[p].append(jid)
    
    queue = deque([jid for jid in job_map if in_degree[jid] == 0])
    visited_count = 0
    while queue:
        u = queue.popleft()
        visited_count += 1
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0:
                queue.append(v)
    if visited_count != len(jobs):
        raise ValueError("Cycle detected")

    # EC3: Resources check
    if not resources_borders and jobs:
        raise ValueError("No resources")

    # Precompute Successors for LES
    successors_count = {jid: 0 for jid in job_map}
    for jid, job in job_map.items():
        for p in job['predecessors']:
            successors_count[p] += 1

    # Note 9: Feasibility check
    for jid, job in job_map.items():
        feasible = False
        for c in resources_borders:
            if all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) 
                   for r in job['work_volume'] if job['work_volume'][r] > 0):
                feasible = True
                break
        if not feasible:
            raise ValueError(f"No feasible contractor for {jid}")

    def compute_duration(job, contractor, allocated):
        max_d = 0
        for r, vol in job['work_volume'].items():
            if vol == 0 or (job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0):
                continue
            prod = allocated[r]
            if communication_coefficient:
                prod *= communication_coefficient(allocated[r], job['demand_max'].get(r, 0))
            max_d = max(max_d, math.ceil(vol / prod))
        return max_d

    # Scheduling state
    current_time = 0
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    completed_jobs = set()
    pending_predecessors = {jid: len(job['predecessors']) for jid, job in job_map.items()}
    unscheduled = set(job_map.keys())
    active_jobs = {} # jid -> end_time

    while unscheduled:
        # 1. COMPLETE
        for jid, end_t in list(active_jobs.items()):
            if end_t <= current_time and jid not in completed_jobs:
                completed_jobs.add(jid)
                for succ in adj[jid]:
                    pending_predecessors[succ] -= 1
                del active_jobs[jid]

        # 2. ELIGIBLE
        eligible = [jid for jid in unscheduled if pending_predecessors[jid] == 0]
        
        # 3. SCHEDULE
        scheduled_any = False
        # Sort eligible by LES rule
        eligible.sort(key=lambda x: successors_count[x])
        
        for jid in eligible:
            job = job_map[jid]
            best_c = None
            best_dur = 0
            best_alloc = {}
            
            # Find feasible contractors
            candidates = []
            for c in resources_borders:
                # Check static capacity
                if not all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in job['work_volume']):
                    continue
                
                # Determine allocation
                alloc = {}
                possible = True
                for r in job['work_volume']:
                    if job['work_volume'][r] == 0: continue
                    # Find min available in future (simplified to current_time for start)
                    # Note: The logic requires checking [start, end). Since duration depends on alloc, 
                    # we iterate until convergence or use max_demand.
                    alloc[r] = min(job['demand_max'][r], c['workers'][r])
                
                dur = compute_duration(job, c, alloc)
                
                # Check resource availability for [current_time, current_time + dur)
                for t in range(current_time, current_time + dur):
                    for r in job['work_volume']:
                        if c['workers'][r] - resource_usage[c['id']][t][r] < job['demand_min'].get(r, 0):
                            possible = False; break
                    if not possible: break
                
                if possible:
                    candidates.append((c, dur, alloc))
            
            if candidates:
                # Pick contractor: smallest sum of workers, then lexicographical ID
                best_c, best_dur, best_alloc = min(candidates, key=lambda x: (sum(x[0]['workers'].values()), x[0]['id']))
                
                # Allocate
                for t in range(current_time, current_time + best_dur):
                    for r, val in best_alloc.items():
                        resource_usage[best_c['id']][t][r] += val
                
                schedule[jid] = (best_c['id'], current_time, current_time + best_dur)
                execution_order.append(jid)
                job_usage[jid] = best_alloc
                active_jobs[jid] = current_time + best_dur
                unscheduled.remove(jid)
                scheduled_any = True

        # 4. ADVANCE
        if not scheduled_any:
            if not active_jobs: raise ValueError("Deadlock detected")
            current_time = min(active_jobs.values())

    makespan = max(end for _, _, end in schedule.values())
    return schedule, execution_order, resource_usage, job_usage, makespan