import math
import signal
from collections import defaultdict, deque
from typing import Callable, Dict, List, Tuple, Any, Optional

def rcpsp_solver(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None,
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    """
    Solve RCPSP using Earliest Finish Time (EFT) priority rule.
    
    Returns:
        (schedule, execution_order, resource_usage, job_usage, makespan)
    """
    
    def timeout_handler(signum, frame):
        raise TimeoutError("rcpsp_solver exceeded 10 second time limit")
    
    signal.signal(signal.SIGALRM, timeout_handler)
    signal.alarm(10)
    
    try:
        return _rcpsp_solver_impl(jobs, resources_borders, communication_coefficient)
    finally:
        signal.alarm(0)


def _rcpsp_solver_impl(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None,
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    
    # ========== EC0: Validate jobs ==========
    if not isinstance(jobs, list):
        raise ValueError("jobs must be a list")
    
    job_ids_seen = set()
    jobs_dict = {}
    
    for job in jobs:
        if not isinstance(job, dict):
            raise ValueError("Each job must be a dictionary")
        
        required_fields = {"id", "demand_min", "demand_max", "work_volume", "predecessors", "priority"}
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job missing required fields. Required: {required_fields}")
        
        job_id = job["id"]
        if not isinstance(job_id, str):
            raise ValueError(f"Job id must be string, got {type(job_id)}")
        
        if job_id in job_ids_seen:
            raise ValueError(f"Duplicate job id: {job_id}")
        job_ids_seen.add(job_id)
        
        # Normalize predecessors
        preds = job["predecessors"]
        if isinstance(preds, str):
            if preds == "":
                preds = []
            else:
                preds = [preds]
        elif isinstance(preds, list):
            preds = list(preds)
        else:
            raise ValueError(f"Job {job_id}: predecessors must be string or list")
        
        normalized_job = {
            "id": job_id,
            "demand_min": dict(job["demand_min"]),
            "demand_max": dict(job["demand_max"]),
            "work_volume": dict(job["work_volume"]),
            "predecessors": preds,
            "priority": job["priority"],
        }
        jobs_dict[job_id] = normalized_job
    
    # ========== EC1: Validate predecessor references ==========
    for job_id, job in jobs_dict.items():
        for pred_id in job["predecessors"]:
            if pred_id not in jobs_dict:
                raise ValueError(f"Job {job_id}: predecessor {pred_id} not found")
    
    # ========== EC2: Detect cycles ==========
    def has_cycle():
        visited = set()
        rec_stack = set()
        
        def dfs(node):
            visited.add(node)
            rec_stack.add(node)
            for pred in jobs_dict[node]["predecessors"]:
                if pred not in visited:
                    if dfs(pred):
                        return True
                elif pred in rec_stack:
                    return True
            rec_stack.remove(node)
            return False
        
        for job_id in jobs_dict:
            if job_id not in visited:
                if dfs(job_id):
                    return True
        return False
    
    if has_cycle():
        raise ValueError("Precedence graph contains a cycle")
    
    # ========== EC3: Validate resources_borders ==========
    if not jobs_dict and resources_borders:
        pass
    elif jobs_dict and not resources_borders:
        raise ValueError("resources_borders cannot be empty when jobs is non-empty")
    
    if not isinstance(resources_borders, list):
        raise ValueError("resources_borders must be a list")
    
    contractors = {}
    for contractor in resources_borders:
        if not isinstance(contractor, dict):
            raise ValueError("Each contractor must be a dictionary")
        if "id" not in contractor or "workers" not in contractor:
            raise ValueError("Contractor missing 'id' or 'workers'")
        
        contractor_id = contractor["id"]
        if not isinstance(contractor_id, str):
            raise ValueError(f"Contractor id must be string, got {type(contractor_id)}")
        
        contractors[contractor_id] = {
            "id": contractor_id,
            "workers": dict(contractor["workers"]),
        }
    
    # ========== Compute EST/EFT for all jobs ==========
    def compute_est_eft():
        est = {job_id: 0 for job_id in jobs_dict}
        eft = {job_id: 0 for job_id in jobs_dict}
        
        # Topological sort
        in_degree = {job_id: len(jobs_dict[job_id]["predecessors"]) for job_id in jobs_dict}
        queue = deque([job_id for job_id in jobs_dict if in_degree[job_id] == 0])
        topo_order = []
        
        while queue:
            job_id = queue.popleft()
            topo_order.append(job_id)
            
            for other_id, other_job in jobs_dict.items():
                if job_id in other_job["predecessors"]:
                    in_degree[other_id] -= 1
                    if in_degree[other_id] == 0:
                        queue.append(other_id)
        
        # Forward pass
        for job_id in topo_order:
            job = jobs_dict[job_id]
            if job["predecessors"]:
                est[job_id] = max(eft[pred_id] for pred_id in job["predecessors"])
            
            # Compute duration assuming max allocation
            duration = compute_duration(job_id, None, None)
            if duration is None:
                duration = 1
            eft[job_id] = est[job_id] + duration
        
        return est, eft
    
    est_dict, eft_dict = compute_est_eft()
    
    # ========== Note 9: Verify feasibility for each job ==========
    def check_job_feasibility(job_id):
        job = jobs_dict[job_id]
        work_vol = job["work_volume"]
        demand_min = job["demand_min"]
        demand_max = job["demand_max"]
        
        # Identify relevant resources
        relevant_resources = set()
        for r in work_vol:
            if work_vol[r] > 0 and not (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                relevant_resources.add(r)
        
        if not relevant_resources:
            return True
        
        for contractor_id, contractor in contractors.items():
            workers = contractor["workers"]
            feasible = True
            for r in relevant_resources:
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    feasible = False
                    break
            if feasible:
                return True
        
        return False
    
    for job_id in jobs_dict:
        if not check_job_feasibility(job_id):
            raise ValueError(f"Job {job_id} has no feasible contractor")
    
    # ========== Helper functions ==========
    def compute_duration(job_id, contractor_id, start_time):
        """Compute job duration given contractor and start time."""
        job = jobs_dict[job_id]
        work_vol = job["work_volume"]
        demand_min = job["demand_min"]
        demand_max = job["demand_max"]
        
        if contractor_id is None or start_time is None:
            # Precomputation: assume max allocation
            max_duration = 0
            for r in work_vol:
                if work_vol[r] > 0:
                    allocated = demand_max.get(r, 0)
                    if allocated > 0:
                        if communication_coefficient:
                            productivity = allocated * communication_coefficient(allocated, demand_max.get(r, 0))
                        else:
                            productivity = allocated
                        duration = math.ceil(work_vol[r] / productivity)
                        max_duration = max(max_duration, duration)
            return max_duration if max_duration > 0 else 1
        
        # Actual computation with contractor and time
        contractor = contractors[contractor_id]
        workers = contractor["workers"]
        
        # Check feasibility and compute allocation
        allocated = {}
        for r in work_vol:
            if work_vol[r] == 0 or (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                continue
            
            if r not in workers:
                return None
            
            min_req = demand_min.get(r, 0)
            max_req = demand_max.get(r, 0)
            
            if workers[r] < min_req:
                return None
            
            allocated[r] = min(max_req, workers[r])
        
        # Compute duration
        max_duration = 0
        for r in work_vol:
            if work_vol[r] > 0 and r in allocated:
                if communication_coefficient:
                    productivity = allocated[r] * communication_coefficient(allocated[r], demand_max.get(r, 0))
                else:
                    productivity = allocated[r]
                duration = math.ceil(work_vol[r] / productivity)
                max_duration = max(max_duration, duration)
        
        return max_duration if max_duration > 0 else 1
    
    def check_resources(contractor_id, start_time, end_time, job_id):
        """Check if contractor has sufficient resources for job in [start_time, end_time)."""
        job = jobs_dict[job_id]
        work_vol = job["work_volume"]
        demand_min = job["demand_min"]
        demand_max = job["demand_max"]
        contractor = contractors[contractor_id]
        workers = contractor["workers"]
        
        for r in work_vol:
            if work_vol[r] == 0 or (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                continue
            
            if r not in workers:
                return False
            
            min_req = demand_min.get(r, 0)
            
            for t in range(start_time, end_time):
                available = workers[r] - resource_usage[contractor_id][t][r]
                if available < min_req:
                    return False
        
        return True
    
    def allocate_resources(contractor_id, start_time, end_time, job_id):
        """Allocate resources for job and return allocation dict."""
        job = jobs_dict[job_id]
        work_vol = job["work_volume"]
        demand_min = job["demand_min"]
        demand_max = job["demand_max"]
        contractor = contractors[contractor_id]
        workers = contractor["workers"]
        
        allocated = {}
        
        for r in work_vol:
            if work_vol[r] == 0 or (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                continue
            
            min_req = demand_min.get(r, 0)
            max_req = demand_max.get(r, 0)
            
            # Find minimum available across all time slots
            min_available = float('inf')
            for t in range(start_time, end_time):
                available = workers[r] - resource_usage[contractor_id][t][r]
                min_available = min(min_available, available)
            
            alloc = min(max_req, min_available)
            allocated[r] = alloc
            
            # Update resource_usage
            for t in range(start_time, end_time):
                resource_usage[contractor_id][t][r] += alloc
        
        return allocated
    
    # ========== Main scheduling loop ==========
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    job_usage = {}
    
    unscheduled = set(jobs_dict.keys())
    pending_predecessors = {job_id: len(jobs_dict[job_id]["predecessors"]) for job_id in jobs_dict}
    
    # Build successor map
    successors = defaultdict(list)
    for job_id, job in jobs_dict.items():
        for pred_id in job["predecessors"]:
            successors[pred_id].append(job_id)
    
    current_time = 0
    active_jobs = set()
    
    while unscheduled:
        # COMPLETE: Mark jobs as complete and update predecessor counters
        completed_this_round = []
        for job_id in list(active_jobs):
            if job_id in schedule:
                _, _, end_time = schedule[job_id]
                if end_time <= current_time:
                    completed_this_round.append(job_id)
                    active_jobs.discard(job_id)
                    for succ_id in successors[job_id]:
                        pending_predecessors[succ_id] -= 1
        
        # ELIGIBLE: Collect eligible jobs
        eligible = [job_id for job_id in unscheduled if pending_predecessors[job_id] == 0]
        
        # Sort eligible by EFT (priority rule)
        eligible.sort(key=lambda jid: (eft_dict[jid], jobs_dict[jid]["priority"], jid))
        
        # SCHEDULE: Try to schedule each eligible job
        scheduled_this_round = False
        for job_id in eligible:
            job = jobs_dict[job_id]
            
            # Collect feasible contractors
            feasible_contractors = []
            for contractor_id, contractor in contractors.items():
                workers = contractor["workers"]
                work_vol = job["work_volume"]
                demand_min = job["demand_min"]
                
                # Check if contractor has minimum resources
                contractor_feasible = True
                for r in work_vol:
                    if work_vol[r] > 0 and not (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                        if r not in workers or workers[r] < demand_min.get(r, 0):
                            contractor_feasible = False
                            break
                
                if not contractor_feasible:
                    continue
                
                # Compute duration
                duration = compute_duration(job_id, contractor_id, current_time)
                if duration is None:
                    continue
                
                # Check resources
                if not check_resources(contractor_id, current_time, current_time + duration, job_id):
                    continue
                
                feasible_contractors.append((contractor_id, duration))
            
            if feasible_contractors:
                # Pick contractor with smallest total workers, ties broken by id
                feasible_contractors.sort(key=lambda x: (sum(contractors[x[0]]["workers"].values()), x[0]))
                contractor_id, duration = feasible_contractors[0]
                
                start_time = current_time
                end_time = start_time + duration
                
                # Allocate resources
                allocated = allocate_resources(contractor_id, start_time, end_time, job_id)
                
                # Record schedule
                schedule[job_id] = (contractor_id, start_time, end_time)
                execution_order.append(job_id)
                job_usage[job_id] = allocated
                
                # Update tracking
                unscheduled.discard(job_id)
                active_jobs.add(job_id)
                scheduled_this_round = True
        
        # ADVANCE: Move time forward
        if not scheduled_this_round and unscheduled:
            if not active_jobs:
                raise ValueError("Deadlock detected")
            
            next_time = min(schedule[job_id][2] for job_id in active_jobs)
            current_time = next_time
    
    # Compute makespan
    makespan = max((end_time for _, _, end_time in schedule.values()), default=0)
    
    return schedule, execution_order, dict(resource_usage), job_usage, makespan