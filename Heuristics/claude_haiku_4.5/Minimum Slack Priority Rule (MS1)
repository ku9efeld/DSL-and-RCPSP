import math
import signal
from collections import defaultdict, deque
from typing import Dict, List, Tuple, Optional, Callable, Any

def rcpsp_solver(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    """
    Solve RCPSP using Minimum Slack Priority Rule heuristic.
    
    Returns:
        (schedule, execution_order, resource_usage, job_usage, makespan)
    """
    
    def timeout_handler(signum, frame):
        raise TimeoutError("Computation exceeded 10 seconds")
    
    signal.signal(signal.SIGALRM, timeout_handler)
    signal.alarm(10)
    
    try:
        return _rcpsp_solver_impl(jobs, resources_borders, communication_coefficient)
    finally:
        signal.alarm(0)


def _rcpsp_solver_impl(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    
    # ========== EC0: Validate jobs ==========
    if not isinstance(jobs, list):
        raise ValueError("jobs must be a list")
    
    job_ids = set()
    jobs_dict = {}
    
    for job in jobs:
        if not isinstance(job, dict):
            raise ValueError("Each job must be a dictionary")
        
        required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job missing required fields. Required: {required_fields}")
        
        job_id = job['id']
        if not isinstance(job_id, str):
            raise ValueError(f"Job id must be string, got {type(job_id)}")
        
        if job_id in job_ids:
            raise ValueError(f"Duplicate job id: {job_id}")
        
        job_ids.add(job_id)
        
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            if preds == "":
                normalized_preds = []
            else:
                normalized_preds = [preds]
        elif isinstance(preds, list):
            normalized_preds = preds
        else:
            raise ValueError(f"Job {job_id}: predecessors must be string or list")
        
        jobs_dict[job_id] = {
            'id': job_id,
            'demand_min': job['demand_min'],
            'demand_max': job['demand_max'],
            'work_volume': job['work_volume'],
            'predecessors': normalized_preds,
            'priority': job['priority']
        }
    
    # ========== EC1: Validate predecessor references ==========
    for job_id, job in jobs_dict.items():
        for pred_id in job['predecessors']:
            if pred_id not in job_ids:
                raise ValueError(f"Job {job_id}: predecessor {pred_id} not found")
    
    # ========== EC2: Detect cycles ==========
    def has_cycle():
        visited = set()
        rec_stack = set()
        
        def dfs(node):
            visited.add(node)
            rec_stack.add(node)
            
            for succ_id in job_ids:
                if node in jobs_dict[succ_id]['predecessors']:
                    if succ_id not in visited:
                        if dfs(succ_id):
                            return True
                    elif succ_id in rec_stack:
                        return True
            
            rec_stack.remove(node)
            return False
        
        for job_id in job_ids:
            if job_id not in visited:
                if dfs(job_id):
                    return True
        return False
    
    if has_cycle():
        raise ValueError("Precedence graph contains a cycle")
    
    # ========== EC3: Validate resources_borders ==========
    if not job_ids and not resources_borders:
        pass
    elif job_ids and not resources_borders:
        raise ValueError("resources_borders cannot be empty when jobs exist")
    
    contractors_dict = {}
    for contractor in resources_borders:
        if 'id' not in contractor or 'workers' not in contractor:
            raise ValueError("Each contractor must have 'id' and 'workers'")
        contractor_id = contractor['id']
        contractors_dict[contractor_id] = contractor
    
    # ========== Note 9: Verify feasibility for each job ==========
    for job_id, job in jobs_dict.items():
        work_volume = job['work_volume']
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        
        # Identify relevant resource types
        relevant_resources = set()
        for r in work_volume:
            if work_volume[r] > 0:
                if not (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                    relevant_resources.add(r)
        
        feasible = False
        for contractor_id, contractor in contractors_dict.items():
            workers = contractor['workers']
            
            # Check if contractor has all required resources
            all_resources_ok = True
            for r in relevant_resources:
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    all_resources_ok = False
                    break
            
            if all_resources_ok:
                feasible = True
                break
        
        if not feasible and relevant_resources:
            raise ValueError(f"Job {job_id} has no feasible contractor")
    
    # ========== Step 1-5: Calculate EST, EFT, LST, LFT, Slack ==========
    
    # Topological sort for forward/backward pass
    def topological_sort():
        in_degree = {job_id: 0 for job_id in job_ids}
        for job_id in job_ids:
            for pred_id in jobs_dict[job_id]['predecessors']:
                in_degree[job_id] += 1
        
        queue = deque([job_id for job_id in job_ids if in_degree[job_id] == 0])
        topo_order = []
        
        while queue:
            job_id = queue.popleft()
            topo_order.append(job_id)
            
            for succ_id in job_ids:
                if job_id in jobs_dict[succ_id]['predecessors']:
                    in_degree[succ_id] -= 1
                    if in_degree[succ_id] == 0:
                        queue.append(succ_id)
        
        return topo_order
    
    topo_order = topological_sort()
    
    # Forward pass: compute EST and EFT
    est = {job_id: 0 for job_id in job_ids}
    eft = {}
    
    # Precompute durations for all jobs (for forward/backward pass only)
    def compute_duration_for_pass(job_id):
        job = jobs_dict[job_id]
        work_volume = job['work_volume']
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        
        # Find a feasible contractor to estimate duration
        for contractor_id, contractor in contractors_dict.items():
            workers = contractor['workers']
            
            # Check feasibility
            feasible = True
            for r in work_volume:
                if work_volume[r] > 0:
                    if not (demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                        if r not in workers or workers[r] < demand_min.get(r, 0):
                            feasible = False
                            break
            
            if not feasible:
                continue
            
            # Compute duration with this contractor
            max_duration = 0
            for r in work_volume:
                if work_volume[r] == 0:
                    continue
                if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                    continue
                
                allocated = min(demand_max.get(r, 0), workers.get(r, 0))
                if allocated < demand_min.get(r, 0):
                    continue
                
                if communication_coefficient:
                    productivity = allocated * communication_coefficient(allocated, demand_max.get(r, 0))
                else:
                    productivity = allocated
                
                if productivity > 0:
                    duration = math.ceil(work_volume[r] / productivity)
                    max_duration = max(max_duration, duration)
            
            return max(1, max_duration)
        
        return 1
    
    durations_for_pass = {job_id: compute_duration_for_pass(job_id) for job_id in job_ids}
    
    for job_id in topo_order:
        job = jobs_dict[job_id]
        if job['predecessors']:
            est[job_id] = max(eft[pred_id] for pred_id in job['predecessors'])
        eft[job_id] = est[job_id] + durations_for_pass[job_id]
    
    project_end = max(eft.values()) if eft else 0
    
    # Backward pass: compute LST and LFT
    lft = {job_id: project_end for job_id in job_ids}
    lst = {}
    
    # Find successors for each job
    successors = {job_id: [] for job_id in job_ids}
    for job_id in job_ids:
        for pred_id in jobs_dict[job_id]['predecessors']:
            successors[pred_id].append(job_id)
    
    reverse_topo = list(reversed(topo_order))
    for job_id in reverse_topo:
        if successors[job_id]:
            lft[job_id] = min(lst[succ_id] for succ_id in successors[job_id])
        lst[job_id] = lft[job_id] - durations_for_pass[job_id]
    
    # Calculate slack
    slack = {job_id: lst[job_id] - est[job_id] for job_id in job_ids}
    
    # ========== Step 6: Initialize scheduling structures ==========
    current_time = 0
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    job_usage = {}
    
    unscheduled = set(job_ids)
    pending_predecessors = {job_id: len(jobs_dict[job_id]['predecessors']) for job_id in job_ids}
    active_jobs = set()
    completed_jobs = set()
    
    # ========== Helper functions ==========
    
    def compute_duration(job_id: str, contractor_id: str, allocated: Dict[str, int]) -> int:
        """Compute actual duration for a job with given allocation."""
        job = jobs_dict[job_id]
        work_volume = job['work_volume']
        
        max_duration = 0
        for r in work_volume:
            if work_volume[r] == 0:
                continue
            
            productivity = allocated.get(r, 0)
            if communication_coefficient and allocated.get(r, 0) > 0:
                productivity = allocated[r] * communication_coefficient(
                    allocated[r],
                    job['demand_max'].get(r, 0)
                )
            
            if productivity > 0:
                duration = math.ceil(work_volume[r] / productivity)
                max_duration = max(max_duration, duration)
        
        return max(1, max_duration)
    
    def check_resources(
        contractor_id: str,
        start_time: int,
        end_time: int,
        demand_min: Dict[str, int]
    ) -> bool:
        """Check if contractor has sufficient resources for [start_time, end_time)."""
        contractor = contractors_dict[contractor_id]
        workers = contractor['workers']
        
        for t in range(start_time, end_time):
            for r in demand_min:
                if demand_min[r] == 0:
                    continue
                available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                if available < demand_min[r]:
                    return False
        
        return True
    
    def allocate_resources(
        contractor_id: str,
        job_id: str,
        start_time: int,
        end_time: int,
        demand_min: Dict[str, int],
        demand_max: Dict[str, int]
    ) -> Dict[str, int]:
        """Allocate resources and return allocation dict."""
        contractor = contractors_dict[contractor_id]
        workers = contractor['workers']
        
        allocated = {}
        for r in demand_max:
            if demand_max[r] == 0:
                allocated[r] = 0
                continue
            
            # Find minimum available capacity across all time slots
            min_available = float('inf')
            for t in range(start_time, end_time):
                available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                min_available = min(min_available, available)
            
            allocated[r] = min(demand_max[r], max(0, min_available))
        
        # Update resource_usage
        for t in range(start_time, end_time):
            for r in allocated:
                resource_usage[contractor_id][t][r] += allocated[r]
        
        return allocated
    
    # ========== Main scheduling loop ==========
    
    while unscheduled:
        # COMPLETE: Mark jobs as complete and update predecessor counters
        jobs_to_complete = [
            job_id for job_id in active_jobs
            if schedule[job_id][2] <= current_time
        ]
        
        for job_id in jobs_to_complete:
            completed_jobs.add(job_id)
            active_jobs.remove(job_id)
            
            # Update predecessor counters for successors
            for succ_id in successors[job_id]:
                pending_predecessors[succ_id] -= 1
        
        # ELIGIBLE: Collect eligible jobs
        eligible = [
            job_id for job_id in unscheduled
            if pending_predecessors[job_id] == 0
        ]
        
        # Sort eligible by minimum slack (then by duration, then by id)
        eligible_with_keys = [
            (slack[job_id], durations_for_pass[job_id], job_id)
            for job_id in eligible
        ]
        eligible_with_keys.sort()
        eligible_sorted = [job_id for _, _, job_id in eligible_with_keys]
        
        # SCHEDULE: Try to schedule each eligible job
        scheduled_this_round = False
        
        for job_id in eligible_sorted:
            job = jobs_dict[job_id]
            work_volume = job['work_volume']
            demand_min = job['demand_min']
            demand_max = job['demand_max']
            
            # Collect feasible contractors
            feasible_contractors = []
            
            for contractor_id, contractor in contractors_dict.items():
                workers = contractor['workers']
                
                # Check if contractor has all required resources
                all_ok = True
                for r in work_volume:
                    if work_volume[r] == 0:
                        continue
                    if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                        continue
                    if r not in workers or workers[r] < demand_min.get(r, 0):
                        all_ok = False
                        break
                
                if not all_ok:
                    continue
                
                # Check resource availability
                if not check_resources(contractor_id, current_time, current_time + 1000, demand_min):
                    continue
                
                feasible_contractors.append(contractor_id)
            
            if not feasible_contractors:
                continue
            
            # Pick contractor with smallest total workers, ties broken by id
            best_contractor = min(
                feasible_contractors,
                key=lambda cid: (sum(contractors_dict[cid]['workers'].values()), cid)
            )
            
            # Allocate resources and compute duration
            allocated = allocate_resources(
                best_contractor,
                job_id,
                current_time,
                current_time + 1000,  # Temporary upper bound
                demand_min,
                demand_max
            )
            
            # Compute actual duration
            duration = compute_duration(job_id, best_contractor, allocated)
            
            # Update resource_usage with correct time range
            # First, remove the temporary allocation
            for t in range(current_time, current_time + 1000):
                for r in allocated:
                    resource_usage[best_contractor][t][r] -= allocated[r]
            
            # Then allocate for the correct duration
            end_time = current_time + duration
            for t in range(current_time, end_time):
                for r in allocated:
                    resource_usage[best_contractor][t][r] += allocated[r]
            
            # Record schedule
            schedule[job_id] = (best_contractor, current_time, end_time)
            execution_order.append(job_id)
            job_usage[job_id] = allocated.copy()
            
            unscheduled.remove(job_id)
            active_jobs.add(job_id)
            scheduled_this_round = True
        
        # ADVANCE: Move time forward
        if not scheduled_this_round:
            if not active_jobs:
                if unscheduled:
                    raise ValueError("Deadlock detected")
                break
            
            # Advance to next event
            next_time = min(schedule[job_id][2] for job_id in active_jobs)
            current_time = next_time
        else:
            # If we scheduled something, stay at current_time for next iteration
            pass
    
    # ========== Calculate makespan ==========
    makespan = max(schedule[job_id][2] for job_id in schedule) if schedule else 0
    
    # ========== Validate schedule ==========
    # Check precedence constraints
    for job_id, (contractor_id, start_time, end_time) in schedule.items():
        for pred_id in jobs_dict[job_id]['predecessors']:
            pred_end = schedule[pred_id][2]
            if pred_end > start_time:
                raise ValueError(f"Precedence constraint violated: {pred_id} -> {job_id}")
    
    # Check resource constraints
    for contractor_id in contractors_dict:
        workers = contractors_dict[contractor_id]['workers']
        for t in resource_usage[contractor_id]:
            for r in resource_usage[contractor_id][t]:
                if resource_usage[contractor_id][t][r] > workers.get(r, 0):
                    raise ValueError(f"Resource constraint violated at contractor {contractor_id}, time {t}, resource {r}")
    
    return (schedule, execution_order, dict(resource_usage), job_usage, makespan)