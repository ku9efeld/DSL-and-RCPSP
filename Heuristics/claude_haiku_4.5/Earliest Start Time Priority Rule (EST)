import math
import signal
from collections import defaultdict, deque
from typing import Callable, Dict, List, Tuple, Any, Optional

def rcpsp_solver(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    """
    Solve Resource-Constrained Project Scheduling Problem using EST heuristic.
    
    Returns:
        (schedule, execution_order, resource_usage, job_usage, makespan)
    """
    
    def timeout_handler(signum, frame):
        raise TimeoutError("rcpsp_solver exceeded 10 second time limit")
    
    signal.signal(signal.SIGALRM, timeout_handler)
    signal.alarm(10)
    
    try:
        return _rcpsp_solver_impl(jobs, resources_borders, communication_coefficient)
    finally:
        signal.alarm(0)


def _rcpsp_solver_impl(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Optional[Callable[[int, int], float]] = None
) -> Tuple[Dict[str, Tuple[str, int, int]], List[str], Dict, Dict, int]:
    
    # ========== EC0: Validate jobs structure ==========
    if not isinstance(jobs, list):
        raise ValueError("jobs must be a list")
    
    job_ids_seen = set()
    jobs_dict = {}
    
    for job in jobs:
        if not isinstance(job, dict):
            raise ValueError("Each job must be a dictionary")
        
        required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job missing required fields. Required: {required_fields}")
        
        job_id = job['id']
        if not isinstance(job_id, str):
            raise ValueError(f"Job id must be string, got {type(job_id)}")
        
        if job_id in job_ids_seen:
            raise ValueError(f"Duplicate job id: {job_id}")
        job_ids_seen.add(job_id)
        
        # Normalize predecessors
        preds = job['predecessors']
        if isinstance(preds, str):
            if preds == "":
                normalized_preds = []
            else:
                normalized_preds = [preds]
        elif isinstance(preds, list):
            normalized_preds = preds
        else:
            raise ValueError(f"Job {job_id}: predecessors must be string or list")
        
        jobs_dict[job_id] = {
            'id': job_id,
            'demand_min': job['demand_min'],
            'demand_max': job['demand_max'],
            'work_volume': job['work_volume'],
            'predecessors': normalized_preds,
            'priority': job['priority']
        }
    
    # ========== EC1: Validate predecessor references ==========
    for job_id, job in jobs_dict.items():
        for pred_id in job['predecessors']:
            if pred_id not in jobs_dict:
                raise ValueError(f"Job {job_id}: predecessor {pred_id} not found")
    
    # ========== EC2: Detect cycles in precedence graph ==========
    def has_cycle():
        visited = set()
        rec_stack = set()
        
        def dfs(node):
            visited.add(node)
            rec_stack.add(node)
            for pred in jobs_dict[node]['predecessors']:
                if pred not in visited:
                    if dfs(pred):
                        return True
                elif pred in rec_stack:
                    return True
            rec_stack.remove(node)
            return False
        
        for job_id in jobs_dict:
            if job_id not in visited:
                if dfs(job_id):
                    return True
        return False
    
    if has_cycle():
        raise ValueError("Precedence graph contains a cycle")
    
    # ========== EC3: Validate resources_borders ==========
    if not jobs_dict and resources_borders:
        pass  # Empty project is valid
    elif jobs_dict and not resources_borders:
        raise ValueError("jobs is non-empty but resources_borders is empty")
    
    contractors_dict = {c['id']: c for c in resources_borders}
    
    # ========== Note 9: Verify feasibility for each job ==========
    for job_id, job in jobs_dict.items():
        work_vol = job['work_volume']
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        
        # Determine which resources are relevant
        relevant_resources = set()
        for r in work_vol:
            if work_vol[r] > 0:
                relevant_resources.add(r)
        for r in demand_min:
            if demand_min.get(r, 0) > 0 or demand_max.get(r, 0) > 0:
                relevant_resources.add(r)
        
        feasible_contractor_exists = False
        for contractor in resources_borders:
            workers = contractor['workers']
            is_feasible = True
            for r in relevant_resources:
                if r not in workers:
                    is_feasible = False
                    break
                if workers[r] < demand_min.get(r, 0):
                    is_feasible = False
                    break
            if is_feasible:
                feasible_contractor_exists = True
                break
        
        if not feasible_contractor_exists:
            raise ValueError(f"Job {job_id} has no feasible contractor")
    
    # ========== Initialize data structures ==========
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    schedule = {}
    execution_order = []
    unscheduled = set(jobs_dict.keys())
    
    # Compute initial pending_predecessors for scheduling
    pending_predecessors = {job_id: len(jobs_dict[job_id]['predecessors']) for job_id in jobs_dict}
    
    # Track which jobs have completed
    completed_jobs = set()
    
    # Track active jobs (scheduled but not yet completed)
    active_jobs = {}  # job_id -> (contractor_id, start_time, end_time)
    
    # ========== Helper functions ==========
    def compute_duration(contractor_id: str, job_id: str) -> Optional[int]:
        """Compute job duration for given contractor. Returns None if infeasible."""
        contractor = contractors_dict[contractor_id]
        workers = contractor['workers']
        job = jobs_dict[job_id]
        work_vol = job['work_volume']
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        
        # Check if contractor has all required resources
        for r in work_vol:
            if work_vol[r] > 0:
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    return None
        
        # Allocate resources and compute duration
        allocated = {}
        for r in work_vol:
            if work_vol[r] == 0:
                allocated[r] = 0
            elif demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                allocated[r] = 0
            else:
                allocated[r] = min(demand_max.get(r, 0), workers.get(r, 0))
        
        # Compute productivity and duration
        max_duration = 0
        for r in work_vol:
            if work_vol[r] > 0 and allocated[r] > 0:
                if communication_coefficient:
                    productivity = allocated[r] * communication_coefficient(allocated[r], demand_max.get(r, 0))
                else:
                    productivity = allocated[r]
                duration = math.ceil(work_vol[r] / productivity)
                max_duration = max(max_duration, duration)
        
        return max(1, max_duration) if max_duration > 0 else 1
    
    def check_resources(contractor_id: str, job_id: str, start_time: int, end_time: int) -> bool:
        """Check if resources are available for job in [start_time, end_time)."""
        contractor = contractors_dict[contractor_id]
        workers = contractor['workers']
        job = jobs_dict[job_id]
        demand_min = job['demand_min']
        
        for t in range(start_time, end_time):
            for r in demand_min:
                if demand_min.get(r, 0) > 0:
                    available = workers.get(r, 0) - resource_usage[contractor_id][t][r]
                    if available < demand_min.get(r, 0):
                        return False
        return True
    
    def allocate_resources(contractor_id: str, job_id: str, start_time: int, end_time: int) -> Dict[str, int]:
        """Allocate resources and return allocation dict."""
        contractor = contractors_dict[contractor_id]
        workers = contractor['workers']
        job = jobs_dict[job_id]
        work_vol = job['work_volume']
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        
        allocated = {}
        for r in work_vol:
            if work_vol[r] == 0:
                allocated[r] = 0
            elif demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                allocated[r] = 0
            else:
                allocated[r] = min(demand_max.get(r, 0), workers.get(r, 0))
        
        # Update resource_usage
        for t in range(start_time, end_time):
            for r in allocated:
                resource_usage[contractor_id][t][r] += allocated[r]
        
        return allocated
    
    def get_eligible_jobs() -> List[str]:
        """Get all eligible jobs (predecessors completed, not yet scheduled)."""
        eligible = []
        for job_id in unscheduled:
            if pending_predecessors[job_id] == 0:
                eligible.append(job_id)
        return eligible
    
    def select_contractor_for_job(job_id: str, current_time: int) -> Optional[Tuple[str, int]]:
        """
        Select best contractor for job at current_time.
        Returns (contractor_id, duration) or None if no feasible contractor.
        """
        job = jobs_dict[job_id]
        
        feasible = []
        for contractor in resources_borders:
            contractor_id = contractor['id']
            duration = compute_duration(contractor_id, job_id)
            if duration is None:
                continue
            
            end_time = current_time + duration
            if not check_resources(contractor_id, job_id, current_time, end_time):
                continue
            
            feasible.append((contractor_id, duration))
        
        if not feasible:
            return None
        
        # Sort by: (total_workers, contractor_id)
        feasible.sort(key=lambda x: (sum(contractors_dict[x[0]]['workers'].values()), x[0]))
        return feasible[0]
    
    # ========== Main scheduling loop ==========
    current_time = 0
    
    while unscheduled:
        # COMPLETE: Mark jobs as complete and update predecessor counters
        jobs_to_complete = [job_id for job_id in active_jobs 
                           if active_jobs[job_id][2] <= current_time and job_id not in completed_jobs]
        
        for job_id in jobs_to_complete:
            completed_jobs.add(job_id)
            # Update pending_predecessors for successors
            for other_id in jobs_dict:
                if job_id in jobs_dict[other_id]['predecessors']:
                    pending_predecessors[other_id] -= 1
        
        # ELIGIBLE: Collect eligible jobs
        eligible = get_eligible_jobs()
        
        # SCHEDULE: Attempt to schedule each eligible job
        scheduled_any = False
        for job_id in eligible:
            result = select_contractor_for_job(job_id, current_time)
            if result:
                contractor_id, duration = result
                end_time = current_time + duration
                
                # Allocate resources
                allocated = allocate_resources(contractor_id, job_id, current_time, end_time)
                
                # Record schedule
                schedule[job_id] = (contractor_id, current_time, end_time)
                active_jobs[job_id] = (contractor_id, current_time, end_time)
                execution_order.append(job_id)
                unscheduled.remove(job_id)
                scheduled_any = True
        
        # ADVANCE: Move time forward if no job was scheduled
        if not scheduled_any and unscheduled:
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(active_jobs[job_id][2] for job_id in active_jobs)
    
    # ========== Compute job_usage ==========
    job_usage = {}
    for job_id in schedule:
        contractor_id, start_time, end_time = schedule[job_id]
        job_usage[job_id] = defaultdict(lambda: 0)
        
        for t in range(start_time, end_time):
            for r in resource_usage[contractor_id][t]:
                # This is a simplification: we report the max allocation per resource
                job_usage[job_id][r] = max(job_usage[job_id][r], resource_usage[contractor_id][t][r])
    
    # Convert defaultdicts to regular dicts
    job_usage = {k: dict(v) for k, v in job_usage.items()}
    
    # ========== Compute makespan ==========
    makespan = max((schedule[job_id][2] for job_id in schedule), default=0)
    
    # Convert resource_usage to regular nested dicts for output
    resource_usage_output = {}
    for contractor_id in resource_usage:
        resource_usage_output[contractor_id] = {}
        for t in resource_usage[contractor_id]:
            resource_usage_output[contractor_id][t] = dict(resource_usage[contractor_id][t])
    
    return (schedule, execution_order, resource_usage_output, job_usage, makespan)