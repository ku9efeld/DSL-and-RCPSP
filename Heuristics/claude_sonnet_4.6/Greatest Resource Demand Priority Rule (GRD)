import math
import time as time_module
from collections import defaultdict, deque


def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    start_wall = time_module.time()
    TIME_LIMIT = 10.0

    # ── EC0: validate required fields and unique ids ──────────────────────────
    required_fields = {"id", "demand_min", "demand_max", "work_volume", "predecessors", "priority"}
    seen_ids = set()
    for job in jobs:
        missing = required_fields - set(job.keys())
        if missing:
            raise ValueError(f"Job missing fields: {missing}")
        jid = job["id"]
        if jid in seen_ids:
            raise ValueError(f"Duplicate job id: {jid}")
        seen_ids.add(jid)

    # ── Step 1: Parse and normalize ───────────────────────────────────────────
    job_map = {}
    for job in jobs:
        jid = job["id"]
        preds = job["predecessors"]
        if isinstance(preds, str):
            preds = [] if preds == "" else [preds]
        else:
            preds = list(preds)
        job_map[jid] = {
            "id": jid,
            "demand_min": dict(job["demand_min"]),
            "demand_max": dict(job["demand_max"]),
            "work_volume": dict(job["work_volume"]),
            "predecessors": preds,
            "priority": job["priority"],
        }

    # ── EC1: validate predecessor ids ────────────────────────────────────────
    for jid, jdata in job_map.items():
        for pid in jdata["predecessors"]:
            if pid not in job_map:
                raise ValueError(f"Predecessor '{pid}' of job '{jid}' not found")

    # ── Step 2: Build DAG ─────────────────────────────────────────────────────
    successors = defaultdict(list)
    in_degree = {jid: 0 for jid in job_map}
    for jid, jdata in job_map.items():
        for pid in jdata["predecessors"]:
            successors[pid].append(jid)
            in_degree[jid] += 1

    # ── EC2: cycle detection via Kahn's algorithm ─────────────────────────────
    topo_order = []
    queue = deque(jid for jid, deg in in_degree.items() if deg == 0)
    temp_in = dict(in_degree)
    while queue:
        node = queue.popleft()
        topo_order.append(node)
        for succ in successors[node]:
            temp_in[succ] -= 1
            if temp_in[succ] == 0:
                queue.append(succ)
    if len(topo_order) != len(job_map):
        raise ValueError("Cycle detected in precedence graph")

    # ── EC3: resources_borders non-empty ─────────────────────────────────────
    if not resources_borders and jobs:
        raise ValueError("resources_borders is empty but jobs are non-empty")

    # ── Build contractor map ──────────────────────────────────────────────────
    contractor_map = {c["id"]: c for c in resources_borders}
    contractor_ids_sorted = sorted(contractor_map.keys())

    # ── Helper: compute duration ──────────────────────────────────────────────
    def compute_duration(jdata, allocated):
        wv = jdata["work_volume"]
        max_dur = 0
        for r, vol in wv.items():
            if vol == 0:
                continue
            if jdata["demand_min"].get(r, 0) == 0 and jdata["demand_max"].get(r, 0) == 0:
                continue
            alloc_r = allocated.get(r, 0)
            if alloc_r == 0:
                return None  # infeasible
            if communication_coefficient is not None:
                dmax_r = jdata["demand_max"].get(r, 0)
                prod = alloc_r * communication_coefficient(alloc_r, dmax_r)
            else:
                prod = alloc_r
            if prod <= 0:
                return None
            dur = math.ceil(vol / prod)
            if dur > max_dur:
                max_dur = dur
        return max_dur if max_dur > 0 else 0

    # ── Helper: check resource availability ──────────────────────────────────
    def check_resources(contractor_id, start_time, end_time, allocated, workers):
        usage = resource_usage[contractor_id]
        for r, alloc_r in allocated.items():
            if alloc_r == 0:
                continue
            for t in range(start_time, end_time):
                if workers[r] - usage[t][r] < alloc_r:
                    return False
        return True

    def allocate_resources(contractor_id, start_time, end_time, allocated):
        usage = resource_usage[contractor_id]
        for r, alloc_r in allocated.items():
            if alloc_r == 0:
                continue
            for t in range(start_time, end_time):
                usage[t][r] += alloc_r

    # ── Note 9: pre-loop feasibility check ───────────────────────────────────
    for jid, jdata in job_map.items():
        has_feasible = False
        for cid in contractor_ids_sorted:
            workers = contractor_map[cid]["workers"]
            feasible = True
            for r, vol in jdata["work_volume"].items():
                if vol == 0:
                    continue
                dmin = jdata["demand_min"].get(r, 0)
                dmax = jdata["demand_max"].get(r, 0)
                if dmin == 0 and dmax == 0:
                    continue
                if r not in workers or workers[r] < dmin:
                    feasible = False
                    break
            if feasible:
                has_feasible = True
                break
        if not has_feasible:
            raise ValueError(f"Job '{jid}' has no feasible contractor")

    # ── Step 3 & 4: EST and LFT (for tie-breaking) ───────────────────────────
    est = {jid: 0 for jid in job_map}
    # Use a simple precomputed duration estimate for EST/LFT (min workers)
    def estimate_duration(jdata):
        wv = jdata["work_volume"]
        max_dur = 0
        for r, vol in wv.items():
            if vol == 0:
                continue
            dmin = jdata["demand_min"].get(r, 0)
            dmax = jdata["demand_max"].get(r, 0)
            if dmin == 0 and dmax == 0:
                continue
            alloc = max(dmin, 1)
            if communication_coefficient is not None:
                prod = alloc * communication_coefficient(alloc, dmax)
            else:
                prod = alloc
            if prod <= 0:
                prod = 1
            dur = math.ceil(vol / prod)
            if dur > max_dur:
                max_dur = dur
        return max_dur

    est_dur = {jid: estimate_duration(job_map[jid]) for jid in job_map}

    for jid in topo_order:
        for succ in successors[jid]:
            candidate = est[jid] + est_dur[jid]
            if candidate > est[succ]:
                est[succ] = candidate

    # Backward pass for LFT
    project_length = max(est[jid] + est_dur[jid] for jid in job_map) if job_map else 0
    lft = {jid: project_length for jid in job_map}
    for jid in reversed(topo_order):
        for succ in successors[jid]:
            candidate = lft[succ] - est_dur[succ]
            if candidate < lft[jid]:
                lft[jid] = candidate

    # ── Step 5: GRD priority ──────────────────────────────────────────────────
    # Collect all resource types across all contractors
    all_resource_types = set()
    for c in resources_borders:
        all_resource_types.update(c["workers"].keys())

    # Total capacity per resource type (sum across contractors)
    total_capacity = defaultdict(float)
    for c in resources_borders:
        for r, cap in c["workers"].items():
            total_capacity[r] += cap

    grd = {}
    for jid, jdata in job_map.items():
        val = 0.0
        for r in all_resource_types:
            req = jdata["demand_max"].get(r, 0)
            cap = total_capacity[r]
            if cap > 0 and req > 0:
                val += req / cap
        grd[jid] = val

    # ── Precompute sort keys (GRD desc, LFT asc) ─────────────────────────────
    sort_key = {jid: (-grd[jid], lft[jid]) for jid in job_map}

    # ── Step 6: Initialize scheduling environment ─────────────────────────────
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(lambda: 0)))
    schedule = {}          # job_id -> (contractor_id, start_time, end_time)
    execution_order = []
    job_usage = {}

    unscheduled = set(job_map.keys())
    completed = set()
    active_jobs = {}       # job_id -> end_time
    completed_set = set()

    # Predecessor counters for scheduling
    pending_predecessors = {jid: len(jdata["predecessors"]) for jid, jdata in job_map.items()}

    current_time = 0

    # ── Main scheduling loop ──────────────────────────────────────────────────
    while unscheduled:
        if time_module.time() - start_wall > TIME_LIMIT:
            break

        # Step 5.1: COMPLETE
        newly_completed = [jid for jid, et in list(active_jobs.items()) if et <= current_time]
        for jid in newly_completed:
            if jid not in completed_set:
                completed_set.add(jid)
                del active_jobs[jid]
                for succ in successors[jid]:
                    pending_predecessors[succ] -= 1

        # Step 5.2: ELIGIBLE
        eligible = [jid for jid in unscheduled if pending_predecessors[jid] == 0]
        # Sort eligible by precomputed key (GRD desc, LFT asc)
        eligible.sort(key=lambda jid: sort_key[jid])

        # Step 5.3: SCHEDULE
        scheduled_any = False
        for jid in eligible:
            if jid not in unscheduled:
                continue

            jdata = job_map[jid]
            wv = jdata["work_volume"]

            # Collect feasible contractors
            feasible_contractors = []
            for cid in contractor_ids_sorted:
                workers = contractor_map[cid]["workers"]

                # Check basic feasibility (workers >= demand_min for relevant resources)
                basic_ok = True
                for r, vol in wv.items():
                    if vol == 0:
                        continue
                    dmin = jdata["demand_min"].get(r, 0)
                    dmax = jdata["demand_max"].get(r, 0)
                    if dmin == 0 and dmax == 0:
                        continue
                    if r not in workers or workers[r] < dmin:
                        basic_ok = False
                        break
                if not basic_ok:
                    continue

                # Compute allocated workers
                allocated = {}
                for r, vol in wv.items():
                    if vol == 0:
                        continue
                    dmin = jdata["demand_min"].get(r, 0)
                    dmax = jdata["demand_max"].get(r, 0)
                    if dmin == 0 and dmax == 0:
                        continue
                    avail_r = workers.get(r, 0)
                    # Check minimum availability at current_time (we'll do full check after duration)
                    # For now compute tentative allocation
                    alloc_r = min(dmax, avail_r)
                    allocated[r] = alloc_r

                # Compute duration
                dur = compute_duration(jdata, allocated)
                if dur is None:
                    continue

                end_time = current_time + dur

                # Refine allocation: min over [current_time, end_time) of available
                refined_allocated = {}
                infeasible = False
                for r, vol in wv.items():
                    if vol == 0:
                        continue
                    dmin = jdata["demand_min"].get(r, 0)
                    dmax = jdata["demand_max"].get(r, 0)
                    if dmin == 0 and dmax == 0:
                        continue
                    workers_r = workers.get(r, 0)
                    usage_cid = resource_usage[cid]
                    min_avail = workers_r
                    for t in range(current_time, end_time):
                        avail_t = workers_r - usage_cid[t][r]
                        if avail_t < min_avail:
                            min_avail = avail_t
                        if avail_t < dmin:
                            infeasible = True
                            break
                    if infeasible:
                        break
                    refined_allocated[r] = min(dmax, min_avail)

                if infeasible:
                    continue

                # Recompute duration with refined allocation
                dur2 = compute_duration(jdata, refined_allocated)
                if dur2 is None:
                    continue

                end_time2 = current_time + dur2

                # Check resources for [current_time, end_time2)
                if not check_resources(cid, current_time, end_time2, refined_allocated, workers):
                    continue

                total_workers = sum(workers.values())
                feasible_contractors.append((total_workers, cid, refined_allocated, dur2, end_time2))

            if not feasible_contractors:
                continue

            # EC4: pick contractor with smallest total workers, ties by lex id
            feasible_contractors.sort(key=lambda x: (x[0], x[1]))
            best = feasible_contractors[0]
            _, best_cid, best_allocated, best_dur, best_end = best

            # Schedule the job
            st = current_time
            et = best_end

            schedule[jid] = (best_cid, st, et)
            allocate_resources(best_cid, st, et, best_allocated)
            execution_order.append(jid)
            unscheduled.remove(jid)
            active_jobs[jid] = et
            scheduled_any = True

            # job_usage
            job_usage[jid] = dict(best_allocated)

        # Step 5.4: ADVANCE
        if not scheduled_any and unscheduled:
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(active_jobs.values())

    # ── Step 16: Makespan ─────────────────────────────────────────────────────
    if schedule:
        makespan = max(et for _, st, et in schedule.values())
    else:
        makespan = 0

    # ── Step 17: Validate ─────────────────────────────────────────────────────
    # Precedence feasibility
    for jid, jdata in job_map.items():
        if jid not in schedule:
            continue
        _, st_j, et_j = schedule[jid]
        for pid in jdata["predecessors"]:
            if pid not in schedule:
                continue
            _, st_p, et_p = schedule[pid]
            if et_p > st_j:
                raise ValueError(f"Precedence violation: {pid} -> {jid}")

    return schedule, execution_order, resource_usage, job_usage, makespan