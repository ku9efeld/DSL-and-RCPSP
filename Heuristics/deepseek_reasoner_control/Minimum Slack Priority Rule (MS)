import heapq
import math
import time
from collections import defaultdict, deque
from typing import Dict, List, Tuple, Set, Optional, Callable


def rcpsp_solver(jobs: List[dict], resources_borders: List[dict], 
                 communication_coefficient: Optional[Callable] = None) -> Tuple[Dict, List, Dict, float]:
    """
    RCPSP solver with Minimum Slack Priority Rule heuristic.
    
    Returns:
        schedule: Dict[job_id] -> (contractor_id, start_time, end_time)
        execution_order: List of job_ids in assignment order
        resource_usage: Dict[contractor_id][time_slot][resource_type] -> allocated_count
        makespan: Total project duration
    """
    
    # ---------------------
    # 1. INPUT VALIDATION
    # ---------------------
    start_execution = time.time()
    
    # EC0: Validate job fields and uniqueness
    job_ids = set()
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    
    for job in jobs:
        if not all(field in job for field in required_fields):
            raise ValueError(f"Job {job.get('id', 'unknown')} missing required fields")
        if job['id'] in job_ids:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_ids.add(job['id'])
        
        # Normalize predecessors to list
        if isinstance(job['predecessors'], str):
            job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
    
    # EC1: Validate predecessor existence
    all_job_ids = set(j['id'] for j in jobs)
    for job in jobs:
        for pred in job['predecessors']:
            if pred not in all_job_ids:
                raise ValueError(f"Job {job['id']} references non-existent predecessor {pred}")
    
    # EC2: Detect cycles in precedence graph using Kahn's algorithm
    indegree = {job['id']: 0 for job in jobs}
    successors = {job['id']: [] for job in jobs}
    
    for job in jobs:
        for pred in job['predecessors']:
            indegree[job['id']] += 1
            successors[pred].append(job['id'])
    
    queue = deque([job_id for job_id, deg in indegree.items() if deg == 0])
    topological_order = []
    
    while queue:
        job_id = queue.popleft()
        topological_order.append(job_id)
        for succ in successors[job_id]:
            indegree[succ] -= 1
            if indegree[succ] == 0:
                queue.append(succ)
    
    if len(topological_order) != len(jobs):
        raise ValueError("Precedence graph contains a cycle")
    
    # EC3: Validate resources_borders
    if not resources_borders and jobs:
        raise ValueError("No contractors provided but jobs exist")
    
    # Convert resources_borders to dict for O(1) access
    contractors = {c['id']: c['workers'] for c in resources_borders}
    
    # Note 9: Check each job has at least one feasible contractor
    for job in jobs:
        feasible = False
        demand_min = job['demand_min']
        work_volume = job['work_volume']
        
        for contractor_id, workers in contractors.items():
            # Check if contractor has all required resource types
            resource_ok = True
            for r in work_volume:
                if work_volume[r] == 0:
                    continue
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    resource_ok = False
                    break
            
            if resource_ok:
                feasible = True
                break
        
        if not feasible:
            raise ValueError(f"No feasible contractor for job {job['id']}")
    
    # ---------------------
    # 2. DATA STRUCTURES
    # ---------------------
    # Create job lookup dictionary
    job_dict = {job['id']: job for job in jobs}
    
    # Initialize predecessor tracking for scheduling
    pending_predecessors = {job['id']: len(job['predecessors']) for job in jobs}
    
    # For topological analysis (unchanging)
    all_predecessors = {job['id']: set(job['predecessors']) for job in jobs}
    
    # Successor relationships
    job_successors = {job['id']: [] for job in jobs}
    for job in jobs:
        for pred in job['predecessors']:
            job_successors[pred].append(job['id'])
    
    # ---------------------
    # 3. PRIORITY COMPUTATION (Minimum Slack)
    # ---------------------
    # Compute minimum possible duration for priority calculation only
    def compute_min_duration(job_id: str) -> int:
        """Compute minimum possible duration for priority ranking."""
        job = job_dict[job_id]
        work_volume = job['work_volume']
        demand_max = job['demand_max']
        
        if not work_volume:
            return 1  # Default minimum duration
        
        max_duration = 0
        for r, volume in work_volume.items():
            if volume == 0:
                continue
            
            max_workers = demand_max.get(r, 0)
            if max_workers == 0:
                continue
            
            if communication_coefficient:
                productivity = max_workers * communication_coefficient(max_workers, max_workers)
            else:
                productivity = max_workers
            
            if productivity > 0:
                duration = math.ceil(volume / productivity)
                max_duration = max(max_duration, duration)
        
        return max_duration if max_duration > 0 else 1
    
    # Compute EST using forward pass
    est = {job['id']: 0 for job in jobs}
    for job_id in topological_order:
        job = job_dict[job_id]
        if job['predecessors']:
            est[job_id] = max(est[pred] + compute_min_duration(pred) 
                            for pred in job['predecessors'])
    
    # Compute LFT using backward pass
    project_duration = max(est[job_id] + compute_min_duration(job_id) 
                          for job_id in all_job_ids)
    lft = {job['id']: project_duration for job in jobs}
    
    # Process in reverse topological order
    for job_id in reversed(topological_order):
        job = job_dict[job_id]
        if job_successors[job_id]:
            lft[job_id] = min(lft[succ] - compute_min_duration(job_id) 
                            for succ in job_successors[job_id])
    
    # Compute slack for each job
    slack = {}
    for job_id in all_job_ids:
        duration = compute_min_duration(job_id)
        slack[job_id] = lft[job_id] - est[job_id] - duration
    
    # Priority ordering: minimum slack first (MS rule)
    priority_order = sorted(all_job_ids, key=lambda x: slack[x])
    
    # ---------------------
    # 4. SCHEDULING DATA STRUCTURES
    # ---------------------
    # Resource usage tracking
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    
    # Schedule tracking
    schedule = {}
    execution_order = []
    
    # State tracking
    unscheduled_jobs = set(all_job_ids)
    active_jobs = set()  # Jobs that are scheduled but not completed
    
    # For quick lookup of job end times
    job_end_times = {}
    
    # ---------------------
    # 5. HELPER FUNCTIONS
    # ---------------------
    def check_resources(contractor_id: str, start_time: int, duration: int, 
                       demand_min: Dict[str, int]) -> bool:
        """Check if resources are available for the entire duration."""
        workers = contractors[contractor_id]
        
        for t in range(start_time, start_time + duration):
            for r, min_req in demand_min.items():
                if min_req == 0:
                    continue
                available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                if available < min_req:
                    return False
        return True
    
    def allocate_resources(contractor_id: str, start_time: int, duration: int, 
                          allocated: Dict[str, int]):
        """Allocate resources for a job."""
        for t in range(start_time, start_time + duration):
            for r, count in allocated.items():
                resource_usage[contractor_id][t][r] += count
    
    def compute_duration(job_id: str, contractor_id: str, allocated: Dict[str, int]) -> Optional[int]:
        """Compute actual duration for a job with given allocation."""
        job = job_dict[job_id]
        work_volume = job['work_volume']
        demand_max = job['demand_max']
        
        if not work_volume:
            return 1
        
        max_duration = 0
        for r, volume in work_volume.items():
            if volume == 0:
                continue
            
            alloc = allocated.get(r, 0)
            if alloc == 0:
                continue
            
            if communication_coefficient:
                productivity = alloc * communication_coefficient(alloc, demand_max.get(r, 0))
            else:
                productivity = alloc
            
            if productivity > 0:
                duration = math.ceil(volume / productivity)
                max_duration = max(max_duration, duration)
        
        return max_duration if max_duration > 0 else None
    
    def find_feasible_contractor(job_id: str, start_time: int) -> Optional[Tuple[str, Dict[str, int], int]]:
        """Find a feasible contractor for a job at given start time (EC4)."""
        job = job_dict[job_id]
        demand_min = job['demand_min']
        demand_max = job['demand_max']
        work_volume = job['work_volume']
        
        # Filter contractors that have minimum resources
        feasible_contractors = []
        
        for contractor_id, workers in contractors.items():
            # Check if contractor has all required resource types
            resource_ok = True
            for r in work_volume:
                if work_volume[r] == 0:
                    continue
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    resource_ok = False
                    break
            
            if not resource_ok:
                continue
            
            # Try to schedule with minimum resources first to check feasibility
            if not check_resources(contractor_id, start_time, 1, demand_min):
                continue
            
            # Now compute actual allocation and duration
            # First, find maximum allocation possible for initial duration estimate
            initial_duration = compute_min_duration(job_id)
            
            # Iterate to find stable allocation and duration
            for _ in range(10):  # Limit iterations
                # Find available resources for the duration
                available = {}
                workers_dict = contractors[contractor_id]
                
                for r in work_volume:
                    if work_volume[r] == 0:
                        continue
                    
                    # Find minimum available over the time period
                    min_available = float('inf')
                    for t in range(start_time, start_time + initial_duration):
                        current = workers_dict.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                        min_available = min(min_available, current)
                    
                    if min_available < demand_min.get(r, 0):
                        resource_ok = False
                        break
                    
                    # Allocate as much as possible up to demand_max
                    allocated_r = min(demand_max.get(r, 0), min_available)
                    available[r] = allocated_r
                
                if not resource_ok:
                    break
                
                # Compute actual duration with this allocation
                actual_duration = compute_duration(job_id, contractor_id, available)
                if actual_duration is None:
                    resource_ok = False
                    break
                
                if actual_duration == initial_duration:
                    # Duration stabilized, check final feasibility
                    if check_resources(contractor_id, start_time, actual_duration, demand_min):
                        feasible_contractors.append((contractor_id, available, actual_duration))
                    break
                
                initial_duration = actual_duration
            
            if not resource_ok:
                continue
        
        if not feasible_contractors:
            return None
        
        # EC4: Select contractor with smallest total workers, tie-break by contractor id
        def contractor_key(item):
            contractor_id, allocated, duration = item
            total_workers = sum(contractors[contractor_id].values())
            return (total_workers, contractor_id)
        
        best_contractor, best_allocation, best_duration = min(feasible_contractors, key=contractor_key)
        return best_contractor, best_allocation, best_duration
    
    # ---------------------
    # 6. MAIN SCHEDULING LOOP
    # ---------------------
    current_time = 0
    
    while unscheduled_jobs:
        # Check time limit
        if time.time() - start_execution > 10:
            # Return current schedule if time runs out
            makespan = max((end_time for _, _, end_time in schedule.values()), default=0)
            return schedule, execution_order, resource_usage, makespan
        
        # Step 1: COMPLETE - Mark completed jobs
        completed_jobs = set()
        for job_id in list(active_jobs):
            _, _, end_time = schedule[job_id]
            if end_time <= current_time:
                completed_jobs.add(job_id)
                # Release resources (already accounted for in resource_usage)
                # Update pending_predecessors for successors
                for succ in job_successors[job_id]:
                    pending_predecessors[succ] -= 1
        
        # Remove completed jobs from active set
        active_jobs -= completed_jobs
        
        # Step 2: ELIGIBLE - Collect eligible jobs
        eligible_jobs = [job_id for job_id in unscheduled_jobs 
                        if pending_predecessors[job_id] == 0]
        
        # Sort by precomputed priority (minimum slack first)
        eligible_jobs.sort(key=lambda x: priority_order.index(x))
        
        # Step 3: SCHEDULE - Try to schedule eligible jobs
        scheduled_this_iteration = False
        
        for job_id in eligible_jobs:
            # Try to find feasible contractor
            result = find_feasible_contractor(job_id, current_time)
            
            if result:
                contractor_id, allocation, duration = result
                
                # Allocate resources
                allocate_resources(contractor_id, current_time, duration, allocation)
                
                # Update schedule
                end_time = current_time + duration
                schedule[job_id] = (contractor_id, current_time, end_time)
                execution_order.append(job_id)
                
                # Update state
                unscheduled_jobs.remove(job_id)
                active_jobs.add(job_id)
                job_end_times[job_id] = end_time
                
                scheduled_this_iteration = True
                
                # Job remains in eligible list until all are processed
        
        # Step 4: ADVANCE - Time advancement
        if not scheduled_this_iteration and unscheduled_jobs:
            if active_jobs:
                # Advance to next completion time
                next_times = [job_end_times[job_id] for job_id in active_jobs]
                current_time = min(next_times)
            else:
                # EC5: Deadlock detected
                raise ValueError("Deadlock detected")
        elif scheduled_this_iteration:
            # Continue at same time to schedule more jobs
            continue
    
    # ---------------------
    # 7. FINALIZATION
    # ---------------------
    makespan = max((end_time for _, _, end_time in schedule.values()), default=0)
    
    return schedule, execution_order, resource_usage, makespan