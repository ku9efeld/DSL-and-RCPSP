import math
import time
from collections import defaultdict, deque
from typing import Callable, Dict, List, Tuple, Any


def rcpsp_solver(
    jobs: List[Dict[str, Any]],
    resources_borders: List[Dict[str, Any]],
    communication_coefficient: Callable[[int, int], float] = None,
) -> Tuple[
    Dict[str, Tuple[str, int, int]],
    List[str],
    Dict[str, Dict[int, Dict[str, int]]],
    Dict[str, Dict[str, int]],
    int,
]:
    """
    Minimum EST heuristic RCPSP solver with contractor assignment.
    Returns (schedule, execution_order, resource_usage, job_usage, makespan).
    """
    # ---------- 0. time limit ----------
    start_wall = time.time()
    TIME_LIMIT = 10.0

    # ---------- EC0: basic validation ----------
    required_fields = {
        "id",
        "demand_min",
        "demand_max",
        "work_volume",
        "predecessors",
        "priority",
    }
    job_by_id: Dict[str, Dict] = {}
    for job in jobs:
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job {job.get('id')} missing required fields")
        jid = job["id"]
        if jid in job_by_id:
            raise ValueError(f"Duplicate job id: {jid}")
        # normalize predecessors
        pred = job["predecessors"]
        if isinstance(pred, str):
            pred = [] if pred == "" else [pred]
        elif pred is None:
            pred = []
        job["predecessors"] = list(pred)
        job_by_id[jid] = job

    # ---------- EC1: predecessor existence ----------
    for job in jobs:
        for p in job["predecessors"]:
            if p not in job_by_id:
                raise ValueError(f"Predecessor {p} of job {job['id']} not found")

    # ---------- EC2: cycle detection ----------
    indeg: Dict[str, int] = {jid: 0 for jid in job_by_id}
    succ: Dict[str, List[str]] = defaultdict(list)
    for job in jobs:
        for p in job["predecessors"]:
            indeg[job["id"]] += 1
            succ[p].append(job["id"])
    q = deque([jid for jid, d in indeg.items() if d == 0])
    visited = 0
    topological: List[str] = []
    while q:
        if time.time() - start_wall > TIME_LIMIT:
            raise TimeoutError("Computation time exceeded 10 seconds")
        node = q.popleft()
        topological.append(node)
        visited += 1
        for nb in succ[node]:
            indeg[nb] -= 1
            if indeg[nb] == 0:
                q.append(nb)
    if visited != len(job_by_id):
        raise ValueError("Precedence graph contains a cycle")

    # ---------- EC3: resources ----------
    if not resources_borders and job_by_id:
        raise ValueError("No contractors provided while jobs exist")
    contractor_by_id: Dict[str, Dict] = {}
    for c in resources_borders:
        contractor_by_id[c["id"]] = c

    # ---------- Helper: resource feasibility ----------
    def check_resources(
        contractor_id: str, start: int, end: int, allocated: Dict[str, int]
    ) -> bool:
        workers = contractor_by_id[contractor_id]["workers"]
        usage = resource_usage[contractor_id]
        for t in range(start, end):
            for r, need in allocated.items():
                if workers.get(r, 0) - usage[t].get(r, 0) < need:
                    return False
        return True

    def allocate_resources(
        contractor_id: str, start: int, end: int, allocated: Dict[str, int]
    ) -> None:
        usage = resource_usage[contractor_id]
        for t in range(start, end):
            for r, need in allocated.items():
                usage[t][r] += need

    # ---------- Pre‑check: each job has at least one feasible contractor ----------
    def contractor_feasible_base(contractor_id: str, job: Dict) -> bool:
        workers = contractor_by_id[contractor_id]["workers"]
        for r, dmin in job["demand_min"].items():
            if job["work_volume"].get(r, 0) == 0:
                continue
            if workers.get(r, 0) < dmin:
                return False
        return True

    for job in jobs:
        if not any(contractor_feasible_base(cid, job) for cid in contractor_by_id):
            raise ValueError(f"No feasible contractor for job {job['id']}")

    # ---------- Compute EST ignoring resources ----------
    # Use demand_max as infinite resources for duration estimate
    est: Dict[str, int] = {}
    finish_est: Dict[str, int] = {}
    for jid in topological:
        job = job_by_id[jid]
        max_pred_finish = 0
        for p in job["predecessors"]:
            max_pred_finish = max(max_pred_finish, finish_est[p])
        # duration ignoring resources
        dur = 0
        for r, vol in job["work_volume"].items():
            if vol == 0:
                continue
            workers = max(job["demand_max"].get(r, 0), 1)
            dur = max(dur, math.ceil(vol / workers))
        est[jid] = max_pred_finish
        finish_est[jid] = max_pred_finish + dur

    # ---------- Scheduler state ----------
    unscheduled = set(job_by_id.keys())
    completed = set()
    schedule: Dict[str, Tuple[str, int, int]] = {}
    execution_order: List[str] = []
    job_usage: Dict[str, Dict[str, int]] = defaultdict(dict)

    # resource usage: contractor -> time -> resource -> allocated
    resource_usage: Dict[
        str, Dict[int, Dict[str, int]]
    ] = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))

    # pending predecessor counters (copy of indeg)
    pending_pred = {jid: len(job_by_id[jid]["predecessors"]) for jid in job_by_id}
    # active jobs: job_id -> (contractor_id, end_time)
    active_jobs: Dict[str, Tuple[str, int]] = {}

    current_time = 0

    # ---------- Main loop ----------
    while unscheduled:
        if time.time() - start_wall > TIME_LIMIT:
            raise TimeoutError("Computation time exceeded 10 seconds")

        # ---- COMPLETE step ----
        newly_completed = [
            jid for jid, (_, end) in active_jobs.items() if end <= current_time
        ]
        for jid in newly_completed:
            contractor_id, _ = active_jobs.pop(jid)
            completed.add(jid)
            for succ_id in succ.get(jid, []):
                pending_pred[succ_id] -= 1

        # ---- ELIGIBLE step ----
        eligible = [jid for jid in unscheduled if pending_pred[jid] == 0]

        if not eligible:
            # advance time
            if active_jobs:
                current_time = min(end for _, end in active_jobs.values())
                continue
            else:
                raise ValueError("Deadlock detected: no eligible jobs and no active jobs")

        # ---- Minimum EST selection ----
        min_est_val = min(est[jid] for jid in eligible)
        eligible_min = [jid for jid in eligible if est[jid] == min_est_val]

        scheduled_this_round = False

        # ---- SCHEDULE each eligible_min job ----
        for jid in eligible_min:
            job = job_by_id[jid]

            # collect feasible contractors with full checks
            feasible_contractors = []
            for cid, contractor in contractor_by_id.items():
                # basic capacity check
                if not contractor_feasible_base(cid, job):
                    continue

                # compute allocation based on current usage at start time
                allocated: Dict[str, int] = {}
                workers = contractor["workers"]
                usage_now = resource_usage[cid][current_time]
                feasible = True
                for r, dmax in job["demand_max"].items():
                    if job["work_volume"].get(r, 0) == 0:
                        continue
                    available = workers.get(r, 0) - usage_now.get(r, 0)
                    alloc = min(dmax, available)
                    if alloc < job["demand_min"].get(r, 0):
                        feasible = False
                        break
                    allocated[r] = alloc
                if not feasible:
                    continue

                # compute productivity and duration
                prod_vals = []
                for r, vol in job["work_volume"].items():
                    if vol == 0:
                        continue
                    alloc = allocated.get(r, 0)
                    if alloc == 0:
                        feasible = False
                        break
                    if communication_coefficient:
                        prod = alloc * communication_coefficient(alloc, job["demand_max"][r])
                    else:
                        prod = alloc
                    if prod <= 0:
                        feasible = False
                        break
                    prod_vals.append(math.ceil(vol / prod))
                if not feasible or not prod_vals:
                    continue
                duration = max(prod_vals)

                # resource availability over whole interval
                if not check_resources(cid, current_time, current_time + duration, allocated):
                    continue

                # store candidate
                total_capacity = sum(contractor["workers"].values())
                feasible_contractors.append((total_capacity, cid, allocated, duration))

            if not feasible_contractors:
                # cannot schedule now; will be retried later
                continue

            # pick contractor per EC4 rule
            feasible_contractors.sort(key=lambda x: (x[0], x[1]))
            _, chosen_cid, chosen_alloc, chosen_dur = feasible_contractors[0]

            # allocate resources
            allocate_resources(chosen_cid, current_time, current_time + chosen_dur, chosen_alloc)

            # record schedule
            schedule[jid] = (chosen_cid, current_time, current_time + chosen_dur)
            execution_order.append(chosen_cid)
            job_usage[jid] = dict(chosen_alloc)  # copy
            active_jobs[jid] = (chosen_cid, current_time + chosen_dur)

            unscheduled.remove(jid)
            scheduled_this_round = True

        # ---- ADVANCE step if nothing scheduled ----
        if not scheduled_this_round:
            if active_jobs:
                current_time = min(end for _, end in active_jobs.values())
            else:
                raise ValueError("Deadlock detected: no progress possible")

    # ---------- makespan ----------
    makespan = max(end for _, _, end in schedule.values()) if schedule else 0

    # ---------- final feasibility (already ensured) ----------
    # Convert resource_usage to plain dicts for output
    resource_usage_out = {
        cid: {t: dict(rdict) for t, rdict in times.items()}
        for cid, times in resource_usage.items()
    }

    return schedule, execution_order, resource_usage_out, dict(job_usage), makespan