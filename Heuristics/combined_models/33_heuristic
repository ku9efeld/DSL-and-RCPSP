import math
import time
from collections import defaultdict, deque

def rcpsp_solver(jobs, resources_borders, communication_coefficient=None):
    start_wall_clock = time.time()
    
    # EC0: Validate fields and unique IDs
    job_dict = {}
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not all(field in job for field in required_fields):
            raise ValueError("Missing required job fields")
        if job['id'] in job_dict:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_dict[job['id']] = job

    # EC1: Validate predecessor IDs and normalize
    for job in job_dict.values():
        preds = job['predecessors']
        if isinstance(preds, str):
            preds = [preds] if preds != "" else []
        job['predecessors'] = preds
        for p_id in preds:
            if p_id not in job_dict:
                raise ValueError(f"Predecessor {p_id} not found")

    # EC2: Cycle detection (Kahn's algorithm)
    adj = defaultdict(list)
    in_degree = {jid: 0 for jid in job_dict}
    for jid, job in job_dict.items():
        for p_id in job['predecessors']:
            adj[p_id].append(jid)
            in_degree[jid] += 1
    
    queue = deque([jid for jid in job_dict if in_degree[jid] == 0])
    topo_order = []
    while queue:
        u = queue.popleft()
        topo_order.append(u)
        for v in adj[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0:
                queue.append(v)
    if len(topo_order) != len(job_dict):
        raise ValueError("Cycle detected in precedence graph")

    # EC3: Resources check
    if not resources_borders and job_dict:
        raise ValueError("No contractors provided")
    
    contractors = {c['id']: c for c in resources_borders}
    
    def get_duration(job, contractor, start_t, res_usage):
        # Note 3: Ignore resource types where work_volume == 0 or demand_min == demand_max == 0
        relevant_res = [r for r in job['work_volume'] 
                        if job['work_volume'][r] > 0 or (job['demand_min'].get(r, 0) > 0 or job['demand_max'].get(r, 0) > 0)]
        
        if not relevant_res:
            return 0, {}

        # Check static feasibility (Note 9)
        for r in relevant_res:
            if r not in contractor['workers'] or contractor['workers'][r] < job['demand_min'].get(r, 0):
                return None, None

        # Calculate potential allocation and duration
        # Note: Duration depends on allocation, but allocation depends on duration (time window)
        # We assume allocation is constant over the job's duration.
        # Since we don't know duration yet, we check availability at start_t to estimate max possible allocation
        allocations = {}
        for r in relevant_res:
            avail = contractor['workers'].get(r, 0) - res_usage[contractor['id']][start_t][r]
            if avail < job['demand_min'].get(r, 0):
                return None, None
            allocations[r] = min(job['demand_max'].get(r, 0), avail)

        max_dur = 0
        for r in relevant_res:
            if job['work_volume'].get(r, 0) == 0:
                continue
            n = allocations[r]
            m = job['demand_max'].get(r, 0)
            prod = n * communication_coefficient(n, m) if communication_coefficient else n
            if prod <= 0: return None, None
            max_dur = max(max_dur, math.ceil(job['work_volume'][r] / prod))
        
        # Verify resource availability for the entire duration
        for t in range(start_t, start_t + max_dur):
            for r, amt in allocations.items():
                if contractor['workers'].get(r, 0) - res_usage[contractor['id']][t][r] < job['demand_min'].get(r, 0):
                    return None, None
                # Re-adjust allocation to the minimum available over the period
                current_avail = contractor['workers'].get(r, 0) - res_usage[contractor['id']][t][r]
                allocations[r] = min(allocations[r], current_avail)
        
        # Final duration check after allocation adjustment
        final_dur = 0
        for r in relevant_res:
            if job['work_volume'].get(r, 0) == 0: continue
            prod = allocations[r] * (communication_coefficient(allocations[r], job['demand_max'][r]) if communication_coefficient else 1)
            final_dur = max(final_dur, math.ceil(job['work_volume'][r] / prod))
            
        return final_dur, allocations

    # Note 9: Pre-loop validation
    for jid, job in job_dict.items():
        feasible_any = False
        for c in resources_borders:
            relevant = [r for r in job['work_volume'] if job['work_volume'][r] > 0]
            if all(c['workers'].get(r, 0) >= job['demand_min'].get(r, 0) for r in relevant):
                feasible_any = True
                break
        if not feasible_any:
            raise ValueError(f"Job {jid} has no feasible contractor")

    # GRD Priority Calculation
    grd_values = {}
    for jid, job in job_dict.items():
        # Resource Demand = duration * sum(resource units)
        # Since duration is unknown, we use a heuristic duration (work_volume / demand_max) or just work_volume
        # Standard GRD: sum(work_volume[r])
        grd_values[jid] = sum(job['work_volume'].values())

    # Scheduling State
    current_time = 0
    completed = set()
    scheduled_jobs = {} # id -> (contractor_id, start, end)
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = {}
    unscheduled = set(job_dict.keys())
    pending_preds = {jid: len(job['predecessors']) for jid, job in job_dict.items()}
    active_jobs = set()

    # Pre-sort eligible candidates by GRD descending
    sorted_by_grd = sorted(job_dict.keys(), key=lambda x: (grd_values[x], job_dict[x]['priority']), reverse=True)

    while unscheduled:
        if time.time() - start_wall_clock > 10:
            raise TimeoutError("Execution exceeded 10 seconds")

        # 1. COMPLETE
        finished_now = [jid for jid in active_jobs if scheduled_jobs[jid][2] <= current_time]
        for jid in finished_now:
            completed.add(jid)
            active_jobs.remove(jid)
            for successor in adj[jid]:
                pending_preds[successor] -= 1

        # 2. ELIGIBLE
        eligible = [jid for jid in sorted_by_grd if jid in unscheduled and pending_preds[jid] == 0]

        # 3. SCHEDULE
        scheduled_in_this_step = False
        for jid in eligible:
            job = job_dict[jid]
            feasible_contractors = []
            for c_id, contractor in contractors.items():
                dur, allocs = get_duration(job, contractor, current_time, resource_usage)
                if dur is not None:
                    c_weight = sum(contractor['workers'].values())
                    feasible_contractors.append((c_weight, c_id, dur, allocs))
            
            if feasible_contractors:
                # EC4: Smallest total capacity, then lexicographical ID
                feasible_contractors.sort(key=lambda x: (x[0], x[1]))
                _, best_c_id, duration, final_allocs = feasible_contractors[0]
                
                start_t = current_time
                end_t = start_t + duration
                scheduled_jobs[jid] = (best_c_id, start_t, end_t)
                execution_order.append(jid)
                unscheduled.remove(jid)
                active_jobs.add(jid)
                job_usage[jid] = final_allocs
                
                for t in range(start_t, end_t):
                    for r, amt in final_allocs.items():
                        resource_usage[best_c_id][t][r] += amt
                scheduled_in_this_step = True

        # 4. ADVANCE
        if not scheduled_in_this_step and unscheduled:
            if not active_jobs:
                raise ValueError("Deadlock detected")
            current_time = min(scheduled_jobs[jid][2] for jid in active_jobs)
        elif not unscheduled:
            break

    makespan = max(v[2] for v in scheduled_jobs.values()) if scheduled_jobs else 0
    return scheduled_jobs, execution_order, resource_usage, job_usage, makespan
