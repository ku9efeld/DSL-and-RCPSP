    def get_relevant_resources(jdata):
        """Return resource types that matter for this job."""
        relevant = []
        for r in jdata['work_volume']:
            wv = jdata['work_volume'].get(r, 0)
            dmin = jdata['demand_min'].get(r, 0)
            dmax = jdata['demand_max'].get(r, 0)
            if wv == 0 and dmin == 0 and dmax == 0:
                continue
            relevant.append(r)
        return relevant

    def compute_duration(jdata, allocated):
        """Compute job duration given allocated workers."""
        max_dur = 0
        for r, wv in jdata['work_volume'].items():
            dmin = jdata['demand_min'].get(r, 0)
            dmax = jdata['demand_max'].get(r, 0)
            if wv == 0 and dmin == 0 and dmax == 0:
                continue
            if wv == 0:
                continue
