import math
import time
from collections import defaultdict, deque
from typing import Dict, List, Tuple, Optional, Callable

def rcpsp_solver(
    jobs: List[Dict],
    resources_borders: List[Dict],
    communication_coefficient: Optional[Callable[[int, int], float]] = None
) -> Tuple[Dict, List, Dict, Dict, int]:
    """
    Solve RCPSP using SPT priority rule with contractor assignment.
    
    Returns:
        schedule: {job_id: (contractor_id, start_time, end_time)}
        execution_order: list of job_ids in assignment order
        resource_usage: {contractor_id: {time: {resource_type: allocated_count}}}
        job_usage: {job_id: {resource_type: allocated_count}}
        makespan: total project duration
    """
    
    start_wall_time = time.time()
    
    # ==================== VALIDATION EC0 ====================
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    job_ids = set()
    for job in jobs:
        if not all(field in job for field in required_fields):
            raise ValueError(f"Job {job.get('id', 'unknown')} missing required fields")
        if job['id'] in job_ids:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_ids.add(job['id'])
    
    # Normalize predecessors
    for job in jobs:
        preds = job['predecessors']
        if isinstance(preds, str):
            job['predecessors'] = [preds] if preds else []
        elif not isinstance(preds, list):
            raise ValueError(f"Job {job['id']} predecessors must be str or list")
    
    # ==================== VALIDATION EC1 ====================
    all_job_ids = {job['id'] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            if pred_id not in all_job_ids:
                raise ValueError(f"Job {job['id']} references missing predecessor {pred_id}")
    
    # ==================== VALIDATION EC2 ====================
    # Check for cycles using Kahn's algorithm
    indegree = {job_id: 0 for job_id in all_job_ids}
    adjacency = {job_id: [] for job_id in all_job_ids}
    job_by_id = {job['id']: job for job in jobs}
    
    for job in jobs:
        for pred_id in job['predecessors']:
            adjacency[pred_id].append(job['id'])
            indegree[job['id']] += 1
    
    queue = deque([job_id for job_id in all_job_ids if indegree[job_id] == 0])
    topological_order = []
    
    while queue:
        current = queue.popleft()
        topological_order.append(current)
        for neighbor in adjacency[current]:
            indegree[neighbor] -= 1
            if indegree[neighbor] == 0:
                queue.append(neighbor)
    
    if len(topological_order) != len(all_job_ids):
        raise ValueError("Precedence graph contains a cycle")
    
    # ==================== VALIDATION EC3 ====================
    if not resources_borders and jobs:
        raise ValueError("No contractors provided for non-empty job set")
    
    # ==================== PREPROCESSING ====================
    # Build successor lists
    successors = {job_id: [] for job_id in all_job_ids}
    for job in jobs:
        for pred_id in job['predecessors']:
            successors[pred_id].append(job['id'])
    
    # Initialize scheduling structures
    schedule = {}  # job_id -> (contractor_id, start_time, end_time)
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = defaultdict(lambda: defaultdict(int))
    
    # Active jobs: job_id -> end_time
    active_jobs = {}
    
    # Pending predecessor counters (for eligibility)
    pending_preds = {job_id: len(job_by_id[job_id]['predecessors']) for job_id in all_job_ids}
    
    # Unscheduled jobs
    unscheduled = set(all_job_ids)
    
    # ==================== VALIDATION Note9 ====================
    for job in jobs:
        feasible_contractor_exists = False
        work_volume = job['work_volume']
        demand_min = job['demand_min']
        
        # Skip resources with zero work volume or zero demands
        relevant_resources = {
            r for r in work_volume 
            if work_volume[r] > 0 and not (demand_min.get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0)
        }
        
        for contractor in resources_borders:
            workers = contractor['workers']
            feasible = True
            for r in relevant_resources:
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    feasible = False
                    break
            if feasible:
                feasible_contractor_exists = True
                break
        
        if not feasible_contractor_exists and relevant_resources:
            raise ValueError(f"Job {job['id']} has no feasible contractor")
    
    # ==================== HELPER FUNCTIONS ====================
    
    def compute_duration(job: Dict, contractor: Dict, allocated: Dict[str, int]) -> Optional[int]:
        """Compute job duration given allocated resources."""
        work_volume = job['work_volume']
        demand_max = job['demand_max']
        workers = contractor['workers']
        
        # Check basic feasibility
        for r in work_volume:
            if work_volume[r] > 0 and not (job['demand_min'].get(r, 0) == 0 and demand_max.get(r, 0) == 0):
                if r not in workers:
                    return None
                if workers[r] < job['demand_min'].get(r, 0):
                    return None
        
        max_duration = 0
        for r, volume in work_volume.items():
            if volume == 0:
                continue
            if job['demand_min'].get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                continue
            
            alloc = allocated.get(r, 0)
            if alloc == 0:
                return None
            
            if communication_coefficient:
                productivity = alloc * communication_coefficient(alloc, demand_max.get(r, 0))
            else:
                productivity = alloc
            
            if productivity <= 0:
                return None
            
            duration = math.ceil(volume / productivity)
            max_duration = max(max_duration, duration)
        
        return max_duration if max_duration > 0 else None
    
    def check_resources(contractor_id: str, start_time: int, duration: int, 
                       demand_min: Dict[str, int], workers: Dict[str, int]) -> bool:
        """Check if resources are available for the entire duration."""
        for t in range(start_time, start_time + duration):
            for r, min_req in demand_min.items():
                if min_req == 0:
                    continue
                available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                if available < min_req:
                    return False
        return True
    
    def allocate_resources(contractor_id: str, start_time: int, duration: int, 
                          allocated: Dict[str, int]) -> None:
        """Allocate resources for the job duration."""
        for t in range(start_time, start_time + duration):
            for r, count in allocated.items():
                resource_usage[contractor_id][t][r] += count
    
    def get_allocated_resources(job: Dict, contractor: Dict, start_time: int, 
                               duration: int) -> Optional[Dict[str, int]]:
        """Determine how many resources to allocate for each resource type."""
        workers = contractor['workers']
        demand_max = job['demand_max']
        allocated = {}
        
        # For each resource type, allocate as much as available up to demand_max
        for r in job['work_volume']:
            if job['work_volume'][r] == 0:
                continue
            if job['demand_min'].get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                continue
            
            max_alloc = demand_max.get(r, 0)
            if max_alloc == 0:
                continue
            
            # Find minimum available over the duration
            min_available = float('inf')
            for t in range(start_time, start_time + duration):
                available = workers.get(r, 0) - resource_usage[contractor['id']][t].get(r, 0)
                min_available = min(min_available, available)
            
            # Check if minimum requirement can be met
            if min_available < job['demand_min'].get(r, 0):
                return None
            
            allocated[r] = min(max_alloc, min_available)
        
        return allocated
    
    # ==================== MAIN SCHEDULING LOOP ====================
    current_time = 0
    
    while unscheduled:
        # Check wall-clock time limit
        if time.time() - start_wall_time > 10:
            raise TimeoutError("Execution time limit exceeded")
        
        # 1. COMPLETE: Mark completed jobs
        completed = []
        for job_id, end_time in list(active_jobs.items()):
            if end_time <= current_time:
                completed.append(job_id)
                # Update predecessor counters for successors
                for succ_id in successors[job_id]:
                    pending_preds[succ_id] -= 1
        
        for job_id in completed:
            del active_jobs[job_id]
        
        # 2. ELIGIBLE: Collect eligible jobs
        eligible = []
        for job_id in unscheduled:
            if pending_preds[job_id] == 0:
                job = job_by_id[job_id]
                eligible.append((job['priority'], job_id, job))
        
        # Sort by SPT priority (smallest priority value = shortest processing time)
        # Note: priority field is used as processing time estimate for SPT
        eligible.sort(key=lambda x: (x[0], x[1]))  # (priority, job_id)
        
        # 3. SCHEDULE: Attempt to schedule eligible jobs
        scheduled_this_iteration = False
        
        for _, job_id, job in eligible:
            if job_id not in unscheduled:  # Already scheduled in this iteration
                continue
            
            # Find feasible contractors
            feasible_contractors = []
            
            for contractor in resources_borders:
                workers = contractor['workers']
                
                # Check basic resource availability
                basic_feasible = True
                for r in job['work_volume']:
                    if job['work_volume'][r] == 0:
                        continue
                    if job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0:
                        continue
                    if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                        basic_feasible = False
                        break
                
                if not basic_feasible:
                    continue
                
                # Try to allocate resources and compute duration
                allocated = get_allocated_resources(job, contractor, current_time, 1)
                if not allocated:
                    continue
                
                duration = compute_duration(job, contractor, allocated)
                if duration is None:
                    continue
                
                # Check resources for the full duration
                if not check_resources(contractor['id'], current_time, duration, 
                                      job['demand_min'], workers):
                    continue
                
                # Recompute allocation with actual duration
                allocated = get_allocated_resources(job, contractor, current_time, duration)
                if not allocated:
                    continue
                
                # Verify duration consistency
                final_duration = compute_duration(job, contractor, allocated)
                if final_duration != duration:
                    continue
                
                # Contractor is feasible
                total_workers = sum(workers.values())
                feasible_contractors.append((total_workers, contractor['id'], 
                                           contractor, allocated, final_duration))
            
            if not feasible_contractors:
                continue
            
            # Select contractor per EC4
            feasible_contractors.sort(key=lambda x: (x[0], x[1]))  # (total_workers, contractor_id)
            _, contractor_id, contractor, allocated, duration = feasible_contractors[0]
            
            # Schedule the job
            start_time = current_time
            end_time = start_time + duration
            
            # Allocate resources
            allocate_resources(contractor_id, start_time, duration, allocated)
            
            # Update tracking structures
            schedule[job_id] = (contractor_id, start_time, end_time)
            execution_order.append(job_id)
            unscheduled.remove(job_id)
            active_jobs[job_id] = end_time
            
            # Update job_usage (reporting only)
            for r, count in allocated.items():
                job_usage[job_id][r] = count
            
            scheduled_this_iteration = True
        
        # 4. ADVANCE: Time advancement logic
        if not scheduled_this_iteration:
            if not active_jobs:
                if unscheduled:
                    raise ValueError("Deadlock detected")
                break
            
            # Advance to next completion time
            next_time = min(active_jobs.values())
            if next_time <= current_time:
                raise ValueError("Time advancement error")
            current_time = next_time
        else:
            # Stay at current time to schedule more jobs
            pass
    
    # ==================== FINALIZATION ====================
    # Compute makespan
    makespan = 0
    for _, start, end in schedule.values():
        makespan = max(makespan, end)
    
    return schedule, execution_order, resource_usage, job_usage, makespan
