        computed_duration = compute_duration(job, allocated)
        if computed_duration is None:
            return None
        if computed_duration != duration:
            # If duration differs, we must respect actual computed duration.
            # Algorithm Notes say always compute duration at scheduling time; thus we should accept computed_duration.
            duration = computed_duration

        # Update resource_usage for [start_time, start_time+duration)
        for r, alloc_r in allocated.items():
