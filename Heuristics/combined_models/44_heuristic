                    break
            if chosen_contractor is None:
                continue

            # Compute duration at scheduling time by calling allocation helper.
            # We need a duration guess; allocation helper will recompute duration after allocation.
            # We'll use duration_guess from compute_duration with allocation guess at chosen_start.
            # Build allocation guess at [t, t+1) to get duration guess.
            allocated_guess = {}
            ok = True
            for r, wvol in job["work_volume"].items():
                if wvol == 0:
                    continue
                dmin = job["demand_min"].get(r, 0)
                dmax = job["demand_max"].get(r, 0)
                if dmin == 0 and dmax == 0:
                    continue
                if r not in chosen_contractor["workers"]:
                    ok = False
                    break
                residual = chosen_contractor["workers"][r] - resource_usage[chosen_contractor_id][chosen_start][r]
                if residual < dmin:
                    ok = False
                    break
                alloc_r = min(dmax, residual)
                if alloc_r < dmin:
                    ok = False
                    break
                allocated_guess[r] = alloc_r
            if not ok:
                continue

            duration_guess = compute_duration(job, allocated_guess)
            if duration_guess is None or duration_guess <= 0:
                continue

            alloc_res = check_resources_and_allocate(chosen_contractor, job, chosen_start, duration_guess)
            if alloc_res is None:
                continue
            _, final_duration = alloc_res

            end_t = chosen_start + final_duration
            schedule[jid] = (chosen_contractor_id, chosen_start, end_t)
            execution_order.append(jid)
            unscheduled.remove(jid)
            active_jobs.add(jid)
            scheduled_any = True

            # Remove job from eligible immediately after it is scheduled:
            # Since we popped it from heap, it's already removed; no further action needed.

        # 5.4 ADVANCE
        if not scheduled_any and unscheduled:
            if not active_jobs:
                # Deadlock detected
                raise ValueError("Deadlock detected")
            # advance current_time = min(end_time for all jobs in active_jobs)
            min_end = None
            for aj in active_jobs:
                _, _, end_t = schedule[aj]
                if min_end is None or end_t < min_end:
                    min_end = end_t
            current_time = min_end

    # -------------------- Objective: makespan --------------------
    makespan = 0
    for jid, (_, _, end_t) in schedule.items():
        if end_t > makespan:
            makespan = end_t

    return schedule, execution_order, resource_usage, job_usage, makespan
