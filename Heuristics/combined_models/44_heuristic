    # Note: feasibility check uses work_volume[r] > 0 and demand_min[r] etc.

    def compute_duration(job: Dict[str, Any], allocated: Dict[str, int]) -> Optional[int]:
        """
        Job duration = max_r ceil(work_volume[r] / productivity[r])
