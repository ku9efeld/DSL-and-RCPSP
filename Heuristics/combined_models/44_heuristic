            succ_map[pid].append(jid)

    # Kahn's algorithm for cycle detection
    indeg = {jid: len(pred_map[jid]) for jid in job_by_id}
    q = deque([jid for jid, d in indeg.items() if d == 0])
    visited = 0
    while q:
        u = q.popleft()
        visited += 1
        for v in succ_map[u]:
