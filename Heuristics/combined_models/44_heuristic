                return None
            if communication_coefficient is not None:
                prod = alloc_r * communication_coefficient(alloc_r, demand_max.get(r, 0))
            else:
                prod = alloc_r
            if prod is None or prod <= 0:
                return None
            duration = max(duration, int(math.ceil(wvol / prod)))
