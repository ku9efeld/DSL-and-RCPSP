# SOURCE: generation_model='Heuristics/deepseek_chat', original_file='Most Successors Priority Rule (MSP2)'

import math
import time
from collections import defaultdict, deque
from typing import Dict, List, Tuple, Optional, Callable

def rcpsp_solver(jobs: List[dict], resources_borders: List[dict], 
                 communication_coefficient: Optional[Callable[[int, int], float]] = None) -> Tuple[dict, list, dict, dict, float]:
    
    start_wall_time = time.time()
    
    # EC0: Validate job structure and unique ids
    job_ids = set()
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job {job.get('id', 'unknown')} missing required fields")
        if job['id'] in job_ids:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_ids.add(job['id'])
        
        # Normalize predecessors to list
        if isinstance(job['predecessors'], str):
            job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
    
    # EC1: Validate predecessor existence
    all_job_ids = {job['id'] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            if pred_id not in all_job_ids:
                raise ValueError(f"Job {job['id']} references non-existent predecessor {pred_id}")
    
    # EC2: Detect cycles in precedence graph using Kahn's algorithm
    indegree = {job['id']: 0 for job in jobs}
    adjacency = {job['id']: [] for job in jobs}
    
    for job in jobs:
        for pred_id in job['predecessors']:
            adjacency[pred_id].append(job['id'])
            indegree[job['id']] += 1
    
    queue = deque([job_id for job_id, deg in indegree.items() if deg == 0])
    topological_order = []
    
    while queue:
        current = queue.popleft()
        topological_order.append(current)
        for neighbor in adjacency[current]:
            indegree[neighbor] -= 1
            if indegree[neighbor] == 0:
                queue.append(neighbor)
    
    if len(topological_order) != len(jobs):
        raise ValueError("Precedence graph contains a cycle")
    
    # EC3: Validate resources_borders
    if not resources_borders and jobs:
        raise ValueError("No contractors provided for non-empty job set")
    
    # Create job lookup dictionary
    job_dict = {job['id']: job for job in jobs}
    
    # Step 2: Compute total successors for each job (MSP priority)
    # Build reverse adjacency for successor calculation
    reverse_adj = {job_id: [] for job_id in all_job_ids}
    for job in jobs:
        for pred_id in job['predecessors']:
            reverse_adj[pred_id].append(job['id'])
    
    # Compute total successors using DFS memoization
    successor_count = {}
    
    def count_successors(job_id: str) -> int:
        if job_id in successor_count:
            return successor_count[job_id]
        
        count = 0
        stack = [job_id]
        visited = set()
        
        while stack:
            current = stack.pop()
            for successor in reverse_adj.get(current, []):
                if successor not in visited:
                    visited.add(successor)
                    stack.append(successor)
                    count += 1
        
        successor_count[job_id] = count
        return count
    
    for job_id in all_job_ids:
        count_successors(job_id)
    
    # Note 9: Verify each job has at least one feasible contractor
    for job in jobs:
        has_feasible_contractor = False
        work_volume = job['work_volume']
        demand_min = job['demand_min']
        
        for contractor in resources_borders:
            workers = contractor['workers']
            feasible = True
            
            for r in work_volume:
                if work_volume[r] == 0:
                    continue
                if demand_min.get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0:
                    continue
                if r not in workers or workers[r] < demand_min.get(r, 0):
                    feasible = False
                    break
            
            if feasible:
                has_feasible_contractor = True
                break
        
        if not has_feasible_contractor:
            raise ValueError(f"Job {job['id']} has no feasible contractor")
    
    # Initialize scheduling structures
    schedule = {}
    execution_order = []
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    job_usage = defaultdict(lambda: defaultdict(int))
    
    # Initialize job states
    unscheduled_jobs = set(all_job_ids)
    active_jobs = set()  # Jobs that are currently executing
    completed_jobs = set()
    
    # Predecessor counters for scheduling
    pending_predecessors = {}
    for job in jobs:
        pending_predecessors[job['id']] = len(job['predecessors'])
    
    # Helper functions
    def compute_duration(job_id: str, contractor_id: str, allocated: Dict[str, int], 
                        start_time: int) -> Optional[int]:
        """Compute job duration based on allocated resources."""
        job = job_dict[job_id]
        work_volume = job['work_volume']
        demand_max = job['demand_max']
        
        max_duration = 0
        for r in work_volume:
            if work_volume[r] == 0:
                continue
            if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                continue
            
            allocated_r = allocated.get(r, 0)
            if allocated_r == 0:
                return None
            
            if communication_coefficient:
                productivity = allocated_r * communication_coefficient(allocated_r, demand_max.get(r, 0))
            else:
                productivity = allocated_r
            
            if productivity <= 0:
                return None
            
            duration_r = math.ceil(work_volume[r] / productivity)
            max_duration = max(max_duration, duration_r)
        
        return max_duration
    
    def check_resources(contractor_id: str, start_time: int, duration: int, 
                       demand_min: Dict[str, int]) -> bool:
        """Check if resources are available for the entire duration."""
        if duration <= 0:
            return False
        
        workers = None
        for contractor in resources_borders:
            if contractor['id'] == contractor_id:
                workers = contractor['workers']
                break
        
        if workers is None:
            return False
        
        # Check each time slot
        for t in range(start_time, start_time + duration):
            for r, min_req in demand_min.items():
                if min_req > 0:
                    available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                    if available < min_req:
                        return False
        
        return True
    
    def allocate_resources(contractor_id: str, start_time: int, duration: int, 
                          allocated: Dict[str, int]) -> None:
        """Allocate resources for the job duration."""
        for t in range(start_time, start_time + duration):
            for r, count in allocated.items():
                resource_usage[contractor_id][t][r] += count
    
    # Main scheduling loop
    current_time = 0
    
    while unscheduled_jobs:
        # Check time limit
        if time.time() - start_wall_time > 10:
            raise TimeoutError("Execution time limit exceeded")
        
        # Step 1: COMPLETE - Mark completed jobs
        newly_completed = set()
        for job_id in list(active_jobs):
            if job_id in schedule:
                contractor_id, start_time, end_time = schedule[job_id]
                if end_time <= current_time:
                    newly_completed.add(job_id)
                    completed_jobs.add(job_id)
                    active_jobs.remove(job_id)
                    
                    # Update predecessor counters for successors
                    for successor_id in reverse_adj[job_id]:
                        pending_predecessors[successor_id] -= 1
        
        # Step 2: ELIGIBLE - Collect eligible jobs
        eligible_jobs = []
        for job_id in unscheduled_jobs:
            if pending_predecessors[job_id] == 0:
                eligible_jobs.append(job_id)
        
        # Step 3: SCHEDULE - Schedule eligible jobs
        scheduled_this_iteration = False
        
        # Sort eligible jobs by MSP priority (descending successors, tie-break by resource demand)
        def get_priority_key(job_id: str) -> Tuple[int, int]:
            job = job_dict[job_id]
            # Sum of demand_max as tie-breaker (greater is higher priority)
            total_demand = sum(job['demand_max'].values())
            return (-successor_count[job_id], -total_demand)
        
        eligible_jobs.sort(key=get_priority_key)
        
        for job_id in eligible_jobs[:]:  # Iterate over copy
            job = job_dict[job_id]
            demand_min = job['demand_min']
            demand_max = job['demand_max']
            work_volume = job['work_volume']
            
            # Find feasible contractors
            feasible_contractors = []
            
            for contractor in resources_borders:
                contractor_id = contractor['id']
                workers = contractor['workers']
                
                # Check basic feasibility
                basic_feasible = True
                for r in work_volume:
                    if work_volume[r] == 0:
                        continue
                    if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                        continue
                    if r not in workers or workers[r] < demand_min.get(r, 0):
                        basic_feasible = False
                        break
                
                if not basic_feasible:
                    continue
                
                # Determine allocation for this contractor
                allocated = {}
                for r in work_volume:
                    if work_volume[r] == 0:
                        continue
                    if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                        continue
                    
                    # Find minimum available over duration (we'll check this properly later)
                    # For now, allocate up to demand_max based on current availability
                    min_available = float('inf')
                    # We'll properly check in check_resources
                    allocated[r] = min(demand_max.get(r, 0), workers.get(r, 0))
                
                # Compute duration
                duration = compute_duration(job_id, contractor_id, allocated, current_time)
                if duration is None:
                    continue
                
                # Check resource availability for the entire duration
                if check_resources(contractor_id, current_time, duration, demand_min):
                    # Recompute actual allocation based on minimum availability
                    actual_allocated = {}
                    for r in work_volume:
                        if work_volume[r] == 0:
                            continue
                        if demand_min.get(r, 0) == 0 and demand_max.get(r, 0) == 0:
                            continue
                        
                        # Find minimum available over the duration
                        min_available = float('inf')
                        for t in range(current_time, current_time + duration):
                            available = workers.get(r, 0) - resource_usage[contractor_id][t].get(r, 0)
                            min_available = min(min_available, available)
                        
                        # Allocate as much as possible up to demand_max
                        actual_allocated[r] = min(demand_max.get(r, 0), min_available)
                    
                    # Recompute duration with actual allocation
                    actual_duration = compute_duration(job_id, contractor_id, actual_allocated, current_time)
                    if actual_duration is not None and actual_duration > 0:
                        feasible_contractors.append((contractor, actual_allocated, actual_duration))
            
            # EC4: Select contractor
            if feasible_contractors:
                # Sort by total workers (ascending), then by contractor id
                feasible_contractors.sort(key=lambda x: (
                    sum(x[0]['workers'].values()),
                    x[0]['id']
                ))
                
                selected_contractor, allocated, duration = feasible_contractors[0]
                contractor_id = selected_contractor['id']
                end_time = current_time + duration
                
                # Allocate resources
                allocate_resources(contractor_id, current_time, duration, allocated)
                
                # Update schedule
                schedule[job_id] = (contractor_id, current_time, end_time)
                execution_order.append(job_id)
                unscheduled_jobs.remove(job_id)
                active_jobs.add(job_id)
                scheduled_this_iteration = True
                
                # Update job_usage (reporting only)
                for r, count in allocated.items():
                    job_usage[job_id][r] = count
        
        # Step 4: ADVANCE
        if not scheduled_this_iteration:
            if not active_jobs:
                # EC5: Deadlock detection
                if unscheduled_jobs:
                    raise ValueError("Deadlock detected")
            
            # Advance to next completion time
            if active_jobs:
                next_completion = min(schedule[job_id][2] for job_id in active_jobs)
                if next_completion <= current_time:
                    raise ValueError("Time advancement error")
                current_time = next_completion
            else:
                # Should not happen if unscheduled_jobs is non-empty (handled above)
                break
    
    # Calculate makespan
    makespan = 0
    for job_id in all_job_ids:
        if job_id in schedule:
            makespan = max(makespan, schedule[job_id][2])
    
    return schedule, execution_order, dict(resource_usage), dict(job_usage), makespan
