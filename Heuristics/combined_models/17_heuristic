import math
import time
from collections import defaultdict, deque
from typing import Dict, List, Tuple, Optional, Callable

def rcpsp_solver(jobs: List[dict], resources_borders: List[dict], 
                 communication_coefficient: Optional[Callable[[int, int], float]] = None) -> Tuple[dict, list, dict, dict, float]:
    
    start_wall_time = time.time()
    
    # EC0: Validate job fields and unique ids
    job_ids = set()
    required_fields = {'id', 'demand_min', 'demand_max', 'work_volume', 'predecessors', 'priority'}
    for job in jobs:
        if not required_fields.issubset(job.keys()):
            raise ValueError(f"Job {job.get('id', 'unknown')} missing required fields")
        if job['id'] in job_ids:
            raise ValueError(f"Duplicate job id: {job['id']}")
        job_ids.add(job['id'])
        
        # Normalize predecessors
        if isinstance(job['predecessors'], str):
            job['predecessors'] = [job['predecessors']] if job['predecessors'] else []
    
    # EC1: Validate predecessor ids exist
    all_job_ids = {job['id'] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            if pred_id not in all_job_ids:
                raise ValueError(f"Predecessor {pred_id} not found for job {job['id']}")
    
    # EC2: Detect cycles in precedence graph using Kahn's algorithm
    indegree = {job['id']: 0 for job in jobs}
    adjacency = {job['id']: [] for job in jobs}
    for job in jobs:
        for pred_id in job['predecessors']:
            adjacency[pred_id].append(job['id'])
            indegree[job['id']] += 1
    
    queue = deque([job_id for job_id, deg in indegree.items() if deg == 0])
    topological_order = []
    while queue:
        current = queue.popleft()
        topological_order.append(current)
        for neighbor in adjacency[current]:
            indegree[neighbor] -= 1
            if indegree[neighbor] == 0:
                queue.append(neighbor)
    
    if len(topological_order) != len(jobs):
        raise ValueError("Precedence graph contains a cycle")
    
    # EC3: Validate resources_borders
    if not resources_borders and jobs:
        raise ValueError("No contractors provided for non-empty job set")
    
    # Create job lookup dictionary
    job_dict = {job['id']: job for job in jobs}
    
    # Step 1: Calculate EST for each activity using forward pass (ignoring resource constraints)
    est = {job['id']: 0 for job in jobs}
    for job_id in topological_order:
        job = job_dict[job_id]
        if job['predecessors']:
            est[job_id] = max(est[pred_id] for pred_id in job['predecessors'])
        # Duration is not computed here as per Note 4
    
    # Note 9: Verify at least one feasible contractor for each job
    for job in jobs:
        feasible_contractor_found = False
        for contractor in resources_borders:
            workers = contractor['workers']
            feasible = True
            for r in job['work_volume']:
                if job['work_volume'][r] == 0:
                    continue
                if job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0:
                    continue
                if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                    feasible = False
                    break
            if feasible:
                feasible_contractor_found = True
                break
        if not feasible_contractor_found:
            raise ValueError(f"No feasible contractor for job {job['id']}")
    
    # Helper functions
    def compute_duration(job: dict, contractor: dict, allocated: Dict[str, int]) -> Optional[int]:
        """Compute job duration for given contractor and allocation."""
        workers = contractor['workers']
        duration = 0
        
        for r in job['work_volume']:
            if job['work_volume'][r] == 0:
                continue
            if job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0:
                continue
                
            if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                return None
                
            if allocated[r] == 0:
                return None
                
            if communication_coefficient:
                productivity = allocated[r] * communication_coefficient(allocated[r], job['demand_max'].get(r, 0))
            else:
                productivity = allocated[r]
                
            if productivity <= 0:
                return None
                
            resource_duration = math.ceil(job['work_volume'][r] / productivity)
            duration = max(duration, resource_duration)
            
        return duration if duration > 0 else None
    
    def check_resources(contractor_id: str, start_time: int, duration: int, 
                       demand_min: Dict[str, int], demand_max: Dict[str, int]) -> Tuple[bool, Dict[str, int]]:
        """Check if resources are available and compute allocation."""
        if duration <= 0:
            return False, {}
            
        workers = contractor_resources[contractor_id]
        allocated = {}
        
        # Check feasibility and compute allocation for each resource
        for r in set(demand_min.keys()) | set(demand_max.keys()):
            if r not in workers:
                return False, {}
                
            # Find minimum available capacity over the interval
            min_available = float('inf')
            for t in range(start_time, start_time + duration):
                available = workers[r] - resource_usage[contractor_id][t][r]
                if available < demand_min.get(r, 0):
                    return False, {}
                min_available = min(min_available, available)
            
            # Allocate as much as possible up to demand_max
            allocated[r] = min(demand_max.get(r, 0), min_available)
            
        return True, allocated
    
    def allocate_resources(contractor_id: str, start_time: int, duration: int, allocated: Dict[str, int]):
        """Allocate resources for the job."""
        for t in range(start_time, start_time + duration):
            for r, count in allocated.items():
                resource_usage[contractor_id][t][r] += count
    
    # Initialize data structures
    contractor_resources = {c['id']: c['workers'] for c in resources_borders}
    resource_usage = defaultdict(lambda: defaultdict(lambda: defaultdict(int)))
    
    # Scheduling state
    schedule = {}
    execution_order = []
    job_usage = {}
    
    # Track job states
    unscheduled_jobs = set(job['id'] for job in jobs)
    active_jobs = set()  # Jobs that are currently executing
    completed_jobs = set()
    
    # Predecessor counters for scheduling
    pending_predecessors = {job['id']: len(job['predecessors']) for job in jobs}
    
    # Track job completion times
    job_completion_times = {}
    
    current_time = 0
    
    # Main scheduling loop
    while unscheduled_jobs:
        if time.time() - start_wall_time > 10:
            raise TimeoutError("Execution time limit exceeded")
        
        # Step 1: COMPLETE - Mark completed jobs
        newly_completed = []
        for job_id in list(active_jobs):
            if schedule[job_id][2] <= current_time:
                completed_jobs.add(job_id)
                active_jobs.remove(job_id)
                newly_completed.append(job_id)
                
                # Update predecessor counters for successors
                for succ_id in adjacency[job_id]:
                    pending_predecessors[succ_id] -= 1
        
        # Step 2: ELIGIBLE - Collect eligible jobs
        eligible_jobs = [job_id for job_id in unscheduled_jobs 
                        if pending_predecessors[job_id] == 0]
        
        # Sort eligible jobs by EST (Step 5 priority rule)
        # This is precomputed before the loop, so allowed
        eligible_jobs.sort(key=lambda job_id: (est[job_id], job_dict[job_id].get('duration', 0)))
        
        scheduled_this_iteration = False
        
        # Step 3: SCHEDULE - Attempt to schedule eligible jobs
        for job_id in eligible_jobs[:]:  # Copy list as we modify it
            job = job_dict[job_id]
            feasible_contractors = []
            
            # Check each contractor for feasibility
            for contractor in resources_borders:
                contractor_id = contractor['id']
                workers = contractor['workers']
                
                # Check basic resource availability
                basic_feasible = True
                for r in job['work_volume']:
                    if job['work_volume'][r] == 0:
                        continue
                    if job['demand_min'].get(r, 0) == 0 and job['demand_max'].get(r, 0) == 0:
                        continue
                    if r not in workers or workers[r] < job['demand_min'].get(r, 0):
                        basic_feasible = False
                        break
                
                if not basic_feasible:
                    continue
                
                # Try to find a feasible allocation
                # We need to compute duration, which depends on allocation
                # Try allocating maximum possible first
                test_allocated = {}
                for r in set(job['demand_min'].keys()) | set(job['demand_max'].keys()):
                    if r in workers:
                        test_allocated[r] = min(job['demand_max'].get(r, 0), workers[r])
                
                duration = compute_duration(job, contractor, test_allocated)
                if duration is None:
                    continue
                
                # Check resource availability for the duration
                feasible, allocated = check_resources(
                    contractor_id, current_time, duration,
                    job['demand_min'], job['demand_max']
                )
                
                if feasible:
                    # Recompute duration with actual allocation
                    actual_duration = compute_duration(job, contractor, allocated)
                    if actual_duration is not None:
                        feasible_contractors.append((contractor, allocated, actual_duration))
            
            # EC4: Select contractor
            if feasible_contractors:
                # Sort by sum of workers (primary), then contractor id (secondary)
                feasible_contractors.sort(
                    key=lambda x: (sum(x[0]['workers'].values()), x[0]['id'])
                )
                selected_contractor, allocated, duration = feasible_contractors[0]
                contractor_id = selected_contractor['id']
                
                # Allocate resources
                allocate_resources(contractor_id, current_time, duration, allocated)
                
                # Record schedule
                end_time = current_time + duration
                schedule[job_id] = (contractor_id, current_time, end_time)
                execution_order.append(job_id)
                job_usage[job_id] = allocated.copy()
                
                # Update state
                unscheduled_jobs.remove(job_id)
                active_jobs.add(job_id)
                job_completion_times[job_id] = end_time
                scheduled_this_iteration = True
                
                # Remove from eligible list
                eligible_jobs.remove(job_id)
        
        # Step 4: ADVANCE - Advance time if needed
        if not scheduled_this_iteration and unscheduled_jobs:
            if not active_jobs:
                # EC5: Deadlock detection
                raise ValueError("Deadlock detected")
            
            # Advance to next completion time
            next_completion = min(job_completion_times[job_id] for job_id in active_jobs)
            if next_completion <= current_time:
                raise ValueError("Time advancement error")
            current_time = next_completion
        elif scheduled_this_iteration:
            # Stay at current time to schedule more jobs
            continue
        else:
            # All jobs scheduled, break loop
            break
    
    # Compute makespan
    makespan = max(end_time for _, _, end_time in schedule.values()) if schedule else 0
    
    return schedule, execution_order, resource_usage, job_usage, makespan
